services:
  yago-node:
    build:
      context: .
      dockerfile: yagonode/Dockerfile
      args:
        SOURCE_REVISION: ${SOURCE_REVISION:-unknown}
    image: yago-node:latest
    restart: unless-stopped
    ports:
      - "8090:8090"   # peer protocol (P2P /yacy/*) — keep reachable from the network
      - "8080:8080"   # public search (portal, OpenSearch, Tavily API, /yacysearch.*)
      - "9090:9090"   # admin and ops (console, /health, /ready, /metrics)
    environment:
      # Peer identity. Leave unset to have the node generate a hash and name on
      # first start and persist them to its data volume (stable across restarts);
      # set them to pin a specific identity.
      YAGO_PEER_HASH: ${YAGO_PEER_HASH:-}
      YAGO_PEER_NAME: ${YAGO_PEER_NAME:-}
      # Address peers use to reach this node. Leave unset to auto-detect the
      # first non-loopback IPv4; set it explicitly behind NAT or Docker bridge
      # networking, where the container's own address is not reachable.
      YAGO_ADVERTISE_HOST: ${YAGO_ADVERTISE_HOST:-}
      YAGO_PUBLIC_SELF_TEST_URL: ${YAGO_PUBLIC_SELF_TEST_URL:-}
      YAGO_NETWORK_NAME: ${YAGO_NETWORK_NAME:-freeworld}
      # Public search listener address; set to "off" to run a pure peer node.
      YAGO_PUBLIC_ADDR: ${YAGO_PUBLIC_ADDR:-:8080}
      # Public search portal UI at the public listener root (off by default).
      YAGO_PUBLIC_SEARCH_UI_ENABLED: ${YAGO_PUBLIC_SEARCH_UI_ENABLED:-false}
      # Answer plain HTTP with a redirect to HTTPS (for a TLS-terminating proxy).
      YAGO_HTTPS_REDIRECT: ${YAGO_HTTPS_REDIRECT:-false}
      YAGO_SEEDLIST_URLS: >-
        http://sixcooler.de/yacy/seed.txt,
        https://sonst.mifritscher.de/yacy/seed.txt,
        http://5.45.105.16/yacyseed,
        http://yacy.v16.de/seed/seed.txt,
        https://frank-siebert.de/seed.txt,
        http://seedlist.wertewesten.net/seed.txt
      YAGO_CRAWL_RPC_ADDR: ${YAGO_CRAWL_RPC_ADDR:-:9091}
      YAGO_EGRESS_ALLOW_PRIVATE_NETWORKS: ${YAGO_EGRESS_ALLOW_PRIVATE_NETWORKS:-false}
      YAGO_EGRESS_ALLOW_CIDRS: ${YAGO_EGRESS_ALLOW_CIDRS:-}
      YAGO_SEARCH_API_KEY: ${YAGO_SEARCH_API_KEY:-}
      YAGO_ADMIN_USER: ${YAGO_ADMIN_USER:-}
      YAGO_ADMIN_PASSWORD: ${YAGO_ADMIN_PASSWORD:-}
      YAGO_ADMIN_CORS_ORIGINS: ${YAGO_ADMIN_CORS_ORIGINS:-}
      YAGO_SEARCH_CORS_ORIGINS: ${YAGO_SEARCH_CORS_ORIGINS:-}
      YAGO_SEARCH_REMOTE_PEER_TIMEOUT: ${YAGO_SEARCH_REMOTE_PEER_TIMEOUT:-1200ms}
      YAGO_SEARCH_REMOTE_TIMEOUT: ${YAGO_SEARCH_REMOTE_TIMEOUT:-1300ms}
      YAGO_WEB_FALLBACK_ENABLED: ${YAGO_WEB_FALLBACK_ENABLED:-false}
      YAGO_WEB_FALLBACK_PRIVACY: ${YAGO_WEB_FALLBACK_PRIVACY:-}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}
    volumes:
      # Shared /opt/yago layout (OPS-04): index and identity live under
      # /opt/yago/data, operator-managed config files under /opt/yago/etc; both
      # persist across container recreation. Migrating from the pre-layout
      # `yago-data:/data` mount: keep the same named volume and only change the
      # target to /opt/yago/data — the volume's contents (index, identity) are
      # preserved — or keep the old target and set YAGO_DATA_DIR=/data instead.
      - yago-data:/opt/yago/data
      - yago-etc:/opt/yago/etc

  yagocrawler:
    build:
      context: .
      dockerfile: yagocrawler/Dockerfile
      args:
        SOURCE_REVISION: ${SOURCE_REVISION:-unknown}
    image: yagocrawler:latest
    restart: unless-stopped
    depends_on:
      - yago-node
    environment:
      YAGOCRAWLER_NODE_RPC_ADDR: ${YAGOCRAWLER_NODE_RPC_ADDR:-yago-node:9091}
      YAGOCRAWLER_WORKER_ID: ${YAGOCRAWLER_WORKER_ID:-}
      YAGOCRAWLER_METRICS_ADDR: ${YAGOCRAWLER_METRICS_ADDR:-}
      YAGOCRAWLER_SHUTDOWN_GRACE: ${YAGOCRAWLER_SHUTDOWN_GRACE:-10s}
      YAGOCRAWLER_ALLOW_PRIVATE_NETWORKS: ${YAGOCRAWLER_ALLOW_PRIVATE_NETWORKS:-false}
      YAGOCRAWLER_ALLOW_CIDRS: ${YAGOCRAWLER_ALLOW_CIDRS:-}
      YAGOCRAWLER_REQUEST_TIMEOUT: ${YAGOCRAWLER_REQUEST_TIMEOUT:-15s}
      YAGOCRAWLER_CONNECT_TIMEOUT: ${YAGOCRAWLER_CONNECT_TIMEOUT:-5s}
      YAGOCRAWLER_TLS_TIMEOUT: ${YAGOCRAWLER_TLS_TIMEOUT:-5s}
      YAGOCRAWLER_HEADER_TIMEOUT: ${YAGOCRAWLER_HEADER_TIMEOUT:-10s}
      YAGOCRAWLER_MAX_REDIRECTS: ${YAGOCRAWLER_MAX_REDIRECTS:-10}
      YAGOCRAWLER_SITEMAP_URL_LIMIT: ${YAGOCRAWLER_SITEMAP_URL_LIMIT:-10000}
      # Default fetch pace per crawl run, pages per minute (0 = unlimited); the
      # crawl monitor can raise or zero a running crawl per run.
      YAGOCRAWLER_RUN_PAGES_PER_MINUTE: ${YAGOCRAWLER_RUN_PAGES_PER_MINUTE:-30}
      # Slow-path browser: headless Firefox over Marionette. The container image
      # bundles firefox-esr on PATH, so BROWSER_PATH stays empty; a bare-metal/
      # systemd install points it at the host browser (e.g. /usr/bin/firefox-esr).
      # BROWSER_SANDBOX is off so Firefox starts in the container and on hosts
      # that restrict user namespaces; a hardened host may set it true.
      YAGOCRAWLER_BROWSER_PATH: ${YAGOCRAWLER_BROWSER_PATH:-}
      YAGOCRAWLER_BROWSER_SANDBOX: ${YAGOCRAWLER_BROWSER_SANDBOX:-false}
      # Consecutive browser malfunctions before the crawler pauses the browser
      # fallback for a cooldown and serves only the HTTP fast path (0 disables).
      YAGOCRAWLER_BROWSER_FAILURE_THRESHOLD: ${YAGOCRAWLER_BROWSER_FAILURE_THRESHOLD:-5}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}

# Optional TLS-terminating reverse proxy in front of the public and admin
# listeners (pairs with YAGO_HTTPS_REDIRECT=true). Uncomment and provide the
# proxy config; Caddy shown as the smallest example.
#  proxy:
#    image: caddy:2
#    restart: unless-stopped
#    ports:
#      - "80:80"
#      - "443:443"
#    volumes:
#      - ./Caddyfile:/etc/caddy/Caddyfile:ro
#      - caddy-data:/data
#    depends_on:
#      - yago-node

volumes:
  yago-data:
  yago-etc:
#  caddy-data:
