services:
  yago-node:
    build:
      context: .
      dockerfile: yagonode/Dockerfile
      args:
        SOURCE_REVISION: ${SOURCE_REVISION:-unknown}
        VERSION: ${VERSION:-}
    image: yago-node:latest
    restart: unless-stopped
    ports:
      - "8090:8090"   # peer protocol (P2P /yacy/*) — keep reachable from the network
      - "8080:8080"   # public search (portal, OpenSearch, Tavily API, /yacysearch.*)
      - "9090:9090"   # admin and ops (console, /health, /ready, /metrics)
    environment:
      YAGO_DATA_DIR: ${YAGO_DATA_DIR:-/opt/yago/data}
      YAGO_PEER_HASH: ${YAGO_PEER_HASH:-}
      YAGO_PEER_NAME: ${YAGO_PEER_NAME:-}
      YAGO_PEER_BIRTH_DATE: ${YAGO_PEER_BIRTH_DATE:-}
      YAGO_NETWORK_NAME: ${YAGO_NETWORK_NAME:-freeworld}
      YAGO_PEER_ADDR: ${YAGO_PEER_ADDR:-:8090}
      YAGO_PUBLIC_ADDR: ${YAGO_PUBLIC_ADDR:-:8080}
      YAGO_OPS_ADDR: ${YAGO_OPS_ADDR:-:9090}
      YAGO_CRAWL_RPC_ADDR: ${YAGO_CRAWL_RPC_ADDR:-:9091}
      YAGO_ADVERTISE_HOST: ${YAGO_ADVERTISE_HOST:-}
      YAGO_ADVERTISE_PORT: ${YAGO_ADVERTISE_PORT:-}
      YAGO_PUBLIC_SELF_TEST_URL: ${YAGO_PUBLIC_SELF_TEST_URL:-}
      YAGO_SEEDLIST_URLS: ${YAGO_SEEDLIST_URLS:-}
      YAGO_ANNOUNCE_INTERVAL: ${YAGO_ANNOUNCE_INTERVAL:-10m}
      YAGO_GREETS_PER_CYCLE: ${YAGO_GREETS_PER_CYCLE:-16}
      YAGO_LAN_DISCOVERY: ${YAGO_LAN_DISCOVERY:-false}
      YAGO_PEER_HTTPS_PREFERRED: ${YAGO_PEER_HTTPS_PREFERRED:-false}
      YAGO_PEER_ADVERTISE_DIRECT: ${YAGO_PEER_ADVERTISE_DIRECT:-true}
      YAGO_PEER_ADVERTISE_REMOTE_INDEX: ${YAGO_PEER_ADVERTISE_REMOTE_INDEX:-true}
      YAGO_PEER_ADVERTISE_ROOT_NODE: ${YAGO_PEER_ADVERTISE_ROOT_NODE:-false}
      YAGO_PEER_ADVERTISE_SSL: ${YAGO_PEER_ADVERTISE_SSL:-false}

      YAGO_ADMIN_USER: ${YAGO_ADMIN_USER:-}
      YAGO_ADMIN_PASSWORD: ${YAGO_ADMIN_PASSWORD:-}
      YAGO_ADMIN_RESTART_ENABLED: ${YAGO_ADMIN_RESTART_ENABLED:-true}
      YAGO_ADMIN_CORS_ORIGINS: ${YAGO_ADMIN_CORS_ORIGINS:-}
      YAGO_SEARCH_CORS_ORIGINS: ${YAGO_SEARCH_CORS_ORIGINS:-}
      YAGO_TRUSTED_PROXIES: ${YAGO_TRUSTED_PROXIES:-}
      YAGO_EGRESS_ALLOW_PRIVATE_NETWORKS: ${YAGO_EGRESS_ALLOW_PRIVATE_NETWORKS:-false}
      YAGO_EGRESS_ALLOW_CIDRS: ${YAGO_EGRESS_ALLOW_CIDRS:-}
      YAGO_NETWORK_AUTHENTICATION: ${YAGO_NETWORK_AUTHENTICATION:-uncontrolled}
      YAGO_NETWORK_AUTHENTICATION_SECRET: ${YAGO_NETWORK_AUTHENTICATION_SECRET:-}

      YAGO_PUBLIC_SEARCH_UI_ENABLED: ${YAGO_PUBLIC_SEARCH_UI_ENABLED:-false}
      YAGO_HTTPS_REDIRECT: ${YAGO_HTTPS_REDIRECT:-false}
      YAGO_PUBLIC_BASE_URL: ${YAGO_PUBLIC_BASE_URL:-}
      YAGO_SEARCH_API_KEY: ${YAGO_SEARCH_API_KEY:-}
      YAGO_SEARCH_REQUIRE_API_KEY: ${YAGO_SEARCH_REQUIRE_API_KEY:-false}
      YAGO_QUERY_LOG_MODE: ${YAGO_QUERY_LOG_MODE:-off}
      YAGO_METRICS_ENABLED: ${YAGO_METRICS_ENABLED:-true}
      YAGO_INDEX_REMOTE_RESULTS: ${YAGO_INDEX_REMOTE_RESULTS:-true}
      YAGO_SEARCH_LINKS_NEW_TAB: ${YAGO_SEARCH_LINKS_NEW_TAB:-false}
      YAGO_SEARCH_CLICK_CAPTURE: ${YAGO_SEARCH_CLICK_CAPTURE:-false}
      YAGO_SEARCH_REMOTE_PEER_TIMEOUT: ${YAGO_SEARCH_REMOTE_PEER_TIMEOUT:-1200ms}
      YAGO_SEARCH_REMOTE_TIMEOUT: ${YAGO_SEARCH_REMOTE_TIMEOUT:-1300ms}
      YAGO_PEER_SNIPPET_FETCH: ${YAGO_PEER_SNIPPET_FETCH:-true}
      YAGO_SWARM_MORPHOLOGY: ${YAGO_SWARM_MORPHOLOGY:-false}
      YAGO_INGEST_QUALITY_GATE: ${YAGO_INGEST_QUALITY_GATE:-true}

      YAGO_STORAGE_QUOTA: ${YAGO_STORAGE_QUOTA:-1GB}
      YAGO_STORAGE_RESERVED_FREE: ${YAGO_STORAGE_RESERVED_FREE:-1GB}
      YAGO_STORAGE_PRESSURE_HYSTERESIS: ${YAGO_STORAGE_PRESSURE_HYSTERESIS:-256MB}
      YAGO_STORAGE_COMPACTION_INTERVAL: ${YAGO_STORAGE_COMPACTION_INTERVAL:-1d}
      YAGO_STORAGE_AUTOSPLIT: ${YAGO_STORAGE_AUTOSPLIT:-true}
      YAGO_STORAGE_DEFER_FSYNC: ${YAGO_STORAGE_DEFER_FSYNC:-false}
      YAGO_STORAGE_READ_DEFER: ${YAGO_STORAGE_READ_DEFER:-0s}

      YAGO_NETWORK_DHT: ${YAGO_NETWORK_DHT:-true}
      YAGO_DHT_DISTRIBUTION: ${YAGO_DHT_DISTRIBUTION:-true}
      YAGO_DHT_ALLOW_WHILE_CRAWLING: ${YAGO_DHT_ALLOW_WHILE_CRAWLING:-false}
      YAGO_DHT_ALLOW_WHILE_INDEXING: ${YAGO_DHT_ALLOW_WHILE_INDEXING:-true}
      YAGO_DHT_DISTRIBUTION_INTERVAL: ${YAGO_DHT_DISTRIBUTION_INTERVAL:-10s}
      YAGO_DHT_REDUNDANCY: ${YAGO_DHT_REDUNDANCY:-3}
      YAGO_DHT_PARTITION_EXPONENT: ${YAGO_DHT_PARTITION_EXPONENT:-4}
      YAGO_DHT_MINIMUM_PEER_AGE_DAYS: ${YAGO_DHT_MINIMUM_PEER_AGE_DAYS:-3}
      YAGO_DHT_MINIMUM_CONNECTED_PEERS: ${YAGO_DHT_MINIMUM_CONNECTED_PEERS:-33}
      YAGO_DHT_MINIMUM_RWI_WORDS: ${YAGO_DHT_MINIMUM_RWI_WORDS:-100}

      YAGO_WEB_FALLBACK_PRIVACY: ${YAGO_WEB_FALLBACK_PRIVACY:-disabled}
      YAGO_WEB_FALLBACK_BACKEND: ${YAGO_WEB_FALLBACK_BACKEND:-auto}
      YAGO_WEB_FALLBACK_MAX_RESULTS: ${YAGO_WEB_FALLBACK_MAX_RESULTS:-10}
      YAGO_WEB_FALLBACK_TIMEOUT: ${YAGO_WEB_FALLBACK_TIMEOUT:-10s}
      YAGO_WEB_FALLBACK_SAFESEARCH: ${YAGO_WEB_FALLBACK_SAFESEARCH:-moderate}
      YAGO_WEB_FALLBACK_CACHE_TTL: ${YAGO_WEB_FALLBACK_CACHE_TTL:-5m}
      YAGO_WEB_FALLBACK_SEED_CRAWL: ${YAGO_WEB_FALLBACK_SEED_CRAWL:-false}
      YAGO_WEB_FALLBACK_SEED_DEPTH: ${YAGO_WEB_FALLBACK_SEED_DEPTH:-5}
      YAGO_WEB_FALLBACK_SEED_MAX_PAGES: ${YAGO_WEB_FALLBACK_SEED_MAX_PAGES:-250}
      YAGO_EXTRACT_FETCH_ENABLED: ${YAGO_EXTRACT_FETCH_ENABLED:-false}
      YAGO_EXTRACT_FETCH_TIMEOUT: ${YAGO_EXTRACT_FETCH_TIMEOUT:-10s}
      YAGO_EXTRACT_FETCH_MAX_BYTES: ${YAGO_EXTRACT_FETCH_MAX_BYTES:-2097152}

      YAGO_SWARM_SEED_CRAWL: ${YAGO_SWARM_SEED_CRAWL:-true}
      YAGO_SWARM_SEED_DEPTH: ${YAGO_SWARM_SEED_DEPTH:-5}
      YAGO_SWARM_SEED_MAX_PAGES: ${YAGO_SWARM_SEED_MAX_PAGES:-250}

      YAGO_REMOTE_CRAWL_ENABLED: ${YAGO_REMOTE_CRAWL_ENABLED:-false}
      YAGO_REMOTE_CRAWL_TRUSTED_PEERS: ${YAGO_REMOTE_CRAWL_TRUSTED_PEERS:-}
      YAGO_REMOTE_CRAWL_ALLOWED_DESTINATIONS: ${YAGO_REMOTE_CRAWL_ALLOWED_DESTINATIONS:-}
      YAGO_REMOTE_CRAWL_REQUESTS_PER_MINUTE: ${YAGO_REMOTE_CRAWL_REQUESTS_PER_MINUTE:-60}
      YAGO_REMOTE_CRAWL_OUTSTANDING_PER_PEER: ${YAGO_REMOTE_CRAWL_OUTSTANDING_PER_PEER:-10}
      YAGO_REMOTE_CRAWL_LEASE_TTL: ${YAGO_REMOTE_CRAWL_LEASE_TTL:-10m}
      YAGO_REMOTE_CRAWL_QUEUE_CAPACITY: ${YAGO_REMOTE_CRAWL_QUEUE_CAPACITY:-1000}

      YAGO_CRAWLER_WORKERS: ${YAGO_CRAWLER_WORKERS:-4}
      YAGO_CRAWLER_MAX_PAGES_PER_SECOND: ${YAGO_CRAWLER_MAX_PAGES_PER_SECOND:-10}
      YAGO_CRAWLER_MAX_REDIRECTS: ${YAGO_CRAWLER_MAX_REDIRECTS:-10}
      YAGO_CRAWLER_MAX_ACTIVE_RUNS: ${YAGO_CRAWLER_MAX_ACTIVE_RUNS:-32}
      YAGO_CRAWLER_PRIORITIZE_AUTOMATIC_DISCOVERY: ${YAGO_CRAWLER_PRIORITIZE_AUTOMATIC_DISCOVERY:-true}
      YAGO_CRAWLER_MAX_PAGES_PER_RUN: ${YAGO_CRAWLER_MAX_PAGES_PER_RUN:-50000}
      YAGO_CRAWLER_STORAGE_RESERVED_FREE: ${YAGO_CRAWLER_STORAGE_RESERVED_FREE:-1GB}
      YAGO_CRAWLER_STORAGE_PRESSURE_HYSTERESIS: ${YAGO_CRAWLER_STORAGE_PRESSURE_HYSTERESIS:-256MB}
      YAGO_CRAWLER_ALLOW_PRIVATE_NETWORKS: ${YAGO_CRAWLER_ALLOW_PRIVATE_NETWORKS:-false}
      YAGO_CRAWLER_ALLOW_CIDRS: ${YAGO_CRAWLER_ALLOW_CIDRS:-}
      YAGO_CRAWLER_BROWSER_SANDBOX: ${YAGO_CRAWLER_BROWSER_SANDBOX:-false}
      YAGO_CRAWLER_BROWSER_FAILURE_THRESHOLD: ${YAGO_CRAWLER_BROWSER_FAILURE_THRESHOLD:-5}
      YAGO_CRAWLER_BROWSER_PATH: ${YAGO_CRAWLER_BROWSER_PATH:-}
      YAGO_CRAWLER_CONNECT_TIMEOUT: ${YAGO_CRAWLER_CONNECT_TIMEOUT:-5s}
      YAGO_CRAWLER_CRAWL_DELAY: ${YAGO_CRAWLER_CRAWL_DELAY:-1s}
      YAGO_CRAWLER_HEADER_TIMEOUT: ${YAGO_CRAWLER_HEADER_TIMEOUT:-10s}
      YAGO_CRAWLER_MAX_DEPTH: ${YAGO_CRAWLER_MAX_DEPTH:-5}
      YAGO_CRAWLER_MAX_HOST_CONCURRENCY: ${YAGO_CRAWLER_MAX_HOST_CONCURRENCY:-2}
      YAGO_CRAWLER_METRICS_ADDR: ${YAGO_CRAWLER_METRICS_ADDR:-}
      YAGO_CRAWLER_REQUEST_TIMEOUT: ${YAGO_CRAWLER_REQUEST_TIMEOUT:-15s}
      YAGO_CRAWLER_RUN_PAGES_PER_MINUTE: ${YAGO_CRAWLER_RUN_PAGES_PER_MINUTE:-30}
      YAGO_CRAWLER_SITEMAP_URL_LIMIT: ${YAGO_CRAWLER_SITEMAP_URL_LIMIT:-10000}
      YAGO_CRAWLER_TLS_TIMEOUT: ${YAGO_CRAWLER_TLS_TIMEOUT:-5s}
      YAGO_CRAWLER_SHUTDOWN_GRACE: ${YAGO_CRAWLER_SHUTDOWN_GRACE:-10s}
      YAGO_CRAWLER_USER_AGENT: ${YAGO_CRAWLER_USER_AGENT:-}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}
    volumes:
      # Shared /opt/yago layout (OPS-04): index and identity live under
      # /opt/yago/data, operator-managed config files under /opt/yago/etc; both
      # persist across container recreation. Migrating from the pre-layout
      # `yago-data:/data` mount: keep the same named volume and only change the
      # target to /opt/yago/data — the volume's contents (index, identity) are
      # preserved — or keep the old target and set YAGO_DATA_DIR=/data instead.
      - yago-data:/opt/yago/data
      - yago-etc:/opt/yago/etc

  yago-crawler:
    build:
      context: .
      dockerfile: yago-crawler/Dockerfile
      args:
        SOURCE_REVISION: ${SOURCE_REVISION:-unknown}
        VERSION: ${VERSION:-}
    image: yago-crawler:latest
    restart: unless-stopped
    depends_on:
      - yago-node
    environment:
      YAGO_DATA_DIR: ${YAGO_DATA_DIR:-/opt/yago/data}
      YAGO_CRAWLER_NODE_RPC_ADDR: ${YAGO_CRAWLER_NODE_RPC_ADDR:-yago-node:9091}
      YAGO_CRAWLER_WORKER_ID: ${YAGO_CRAWLER_WORKER_ID:-}
      YAGO_CRAWLER_METRICS_ADDR: ${YAGO_CRAWLER_METRICS_ADDR:-}
      YAGO_CRAWLER_BROWSER_PATH: ${YAGO_CRAWLER_BROWSER_PATH:-}
      YAGO_CRAWLER_BROWSER_SANDBOX: ${YAGO_CRAWLER_BROWSER_SANDBOX:-false}
      YAGO_CRAWLER_WORKERS: ${YAGO_CRAWLER_WORKERS:-4}
      YAGO_CRAWLER_MAX_PAGES_PER_SECOND: ${YAGO_CRAWLER_MAX_PAGES_PER_SECOND:-10}
      YAGO_CRAWLER_MAX_ACTIVE_RUNS: ${YAGO_CRAWLER_MAX_ACTIVE_RUNS:-32}
      YAGO_CRAWLER_PRIORITIZE_AUTOMATIC_DISCOVERY: ${YAGO_CRAWLER_PRIORITIZE_AUTOMATIC_DISCOVERY:-true}
      YAGO_CRAWLER_MAX_HOST_CONCURRENCY: ${YAGO_CRAWLER_MAX_HOST_CONCURRENCY:-2}
      YAGO_CRAWLER_MAX_DEPTH: ${YAGO_CRAWLER_MAX_DEPTH:-5}
      YAGO_CRAWLER_MAX_PAGES_PER_RUN: ${YAGO_CRAWLER_MAX_PAGES_PER_RUN:-50000}
      YAGO_CRAWLER_STORAGE_RESERVED_FREE: ${YAGO_CRAWLER_STORAGE_RESERVED_FREE:-1GB}
      YAGO_CRAWLER_STORAGE_PRESSURE_HYSTERESIS: ${YAGO_CRAWLER_STORAGE_PRESSURE_HYSTERESIS:-256MB}
      YAGO_CRAWLER_CRAWL_DELAY: ${YAGO_CRAWLER_CRAWL_DELAY:-1s}
      YAGO_CRAWLER_USER_AGENT: ${YAGO_CRAWLER_USER_AGENT:-}
      YAGO_CRAWLER_SHUTDOWN_GRACE: ${YAGO_CRAWLER_SHUTDOWN_GRACE:-10s}
      YAGO_CRAWLER_ALLOW_PRIVATE_NETWORKS: ${YAGO_CRAWLER_ALLOW_PRIVATE_NETWORKS:-false}
      YAGO_CRAWLER_ALLOW_CIDRS: ${YAGO_CRAWLER_ALLOW_CIDRS:-}
      YAGO_CRAWLER_REQUEST_TIMEOUT: ${YAGO_CRAWLER_REQUEST_TIMEOUT:-15s}
      YAGO_CRAWLER_CONNECT_TIMEOUT: ${YAGO_CRAWLER_CONNECT_TIMEOUT:-5s}
      YAGO_CRAWLER_TLS_TIMEOUT: ${YAGO_CRAWLER_TLS_TIMEOUT:-5s}
      YAGO_CRAWLER_HEADER_TIMEOUT: ${YAGO_CRAWLER_HEADER_TIMEOUT:-10s}
      YAGO_CRAWLER_MAX_REDIRECTS: ${YAGO_CRAWLER_MAX_REDIRECTS:-10}
      YAGO_CRAWLER_SITEMAP_URL_LIMIT: ${YAGO_CRAWLER_SITEMAP_URL_LIMIT:-10000}
      # Default fetch pace per crawl run, pages per minute (0 = unlimited); the
      # crawl monitor can raise or zero a running crawl per run.
      YAGO_CRAWLER_RUN_PAGES_PER_MINUTE: ${YAGO_CRAWLER_RUN_PAGES_PER_MINUTE:-30}
      YAGO_CRAWLER_BROWSER_FAILURE_THRESHOLD: ${YAGO_CRAWLER_BROWSER_FAILURE_THRESHOLD:-5}
    volumes:
      - yago-crawler-data:/opt/yago/data

# Optional TLS-terminating reverse proxy in front of the public and admin
# listeners (pairs with YAGO_HTTPS_REDIRECT=true). Uncomment and provide the
# proxy config; Caddy shown as the smallest example.
#  proxy:
#    image: caddy:2
#    restart: unless-stopped
#    ports:
#      - "80:80"
#      - "443:443"
#    volumes:
#      - ./Caddyfile:/etc/caddy/Caddyfile:ro
#      - caddy-data:/data
#    depends_on:
#      - yago-node

volumes:
  yago-data:
  yago-crawler-data:
  yago-etc:
#  caddy-data:
