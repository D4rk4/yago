services:
  yago-node:
    build:
      context: .
      dockerfile: yacynode/Dockerfile
    image: yago-node:latest
    restart: unless-stopped
    ports:
      - "8090:8090"
      - "9090:9090"
    environment:
      YACY_PEER_HASH: ${YACY_PEER_HASH:?set YACY_PEER_HASH in .env}
      YACY_PEER_NAME: ${YACY_PEER_NAME:?set YACY_PEER_NAME in .env}
      YACY_ADVERTISE_HOST: ${YACY_ADVERTISE_HOST:?set YACY_ADVERTISE_HOST in .env}
      YACY_PUBLIC_SELF_TEST_URL: ${YACY_PUBLIC_SELF_TEST_URL:-}
      YACY_NETWORK_NAME: ${YACY_NETWORK_NAME:-freeworld}
      YACY_SEEDLIST_URLS: >-
        http://sixcooler.de/yacy/seed.txt,
        https://sonst.mifritscher.de/yacy/seed.txt,
        http://5.45.105.16/yacyseed,
        http://yacy.v16.de/seed/seed.txt,
        https://frank-siebert.de/seed.txt,
        http://seedlist.wertewesten.net/seed.txt
      YACY_CRAWL_RPC_ADDR: ${YACY_CRAWL_RPC_ADDR:-:9091}
      YACY_EGRESS_ALLOW_PRIVATE_NETWORKS: ${YACY_EGRESS_ALLOW_PRIVATE_NETWORKS:-false}
      YAGO_SEARCH_API_KEY: ${YAGO_SEARCH_API_KEY:-}
      YAGO_ADMIN_USER: ${YAGO_ADMIN_USER:-}
      YAGO_ADMIN_PASSWORD: ${YAGO_ADMIN_PASSWORD:-}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}
    volumes:
      - yacy-data:/data

  yacycrawler:
    build:
      context: .
      dockerfile: yacycrawler/Dockerfile
    image: yacycrawler:latest
    restart: unless-stopped
    depends_on:
      - yago-node
    environment:
      YACYCRAWLER_NODE_RPC_ADDR: ${YACYCRAWLER_NODE_RPC_ADDR:-yago-node:9091}
      YACYCRAWLER_WORKER_ID: ${YACYCRAWLER_WORKER_ID:-}
      YACYCRAWLER_ALLOW_PRIVATE_NETWORKS: ${YACYCRAWLER_ALLOW_PRIVATE_NETWORKS:-false}
      YACYCRAWLER_REQUEST_TIMEOUT: ${YACYCRAWLER_REQUEST_TIMEOUT:-15s}
      YACYCRAWLER_CONNECT_TIMEOUT: ${YACYCRAWLER_CONNECT_TIMEOUT:-5s}
      YACYCRAWLER_TLS_TIMEOUT: ${YACYCRAWLER_TLS_TIMEOUT:-5s}
      YACYCRAWLER_HEADER_TIMEOUT: ${YACYCRAWLER_HEADER_TIMEOUT:-10s}
      YACYCRAWLER_MAX_REDIRECTS: ${YACYCRAWLER_MAX_REDIRECTS:-10}
      YACYCRAWLER_SITEMAP_URL_LIMIT: ${YACYCRAWLER_SITEMAP_URL_LIMIT:-10000}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}

volumes:
  yacy-data:
