services:
  nats:
    image: nats:2.14.2
    restart: unless-stopped
    command: ["-js"]
    ports:
      - "4222:4222"

  yago-node:
    build:
      context: .
      dockerfile: yacynode/Dockerfile
    image: yago-node:latest
    restart: unless-stopped
    depends_on:
      - nats
      - smokescreen
    ports:
      - "8090:8090"
      - "9090:9090"
    environment:
      YACY_PEER_HASH: ${YACY_PEER_HASH:?set YACY_PEER_HASH in .env}
      YACY_PEER_NAME: ${YACY_PEER_NAME:?set YACY_PEER_NAME in .env}
      YACY_ADVERTISE_HOST: ${YACY_ADVERTISE_HOST:?set YACY_ADVERTISE_HOST in .env}
      YACY_PUBLIC_SELF_TEST_URL: ${YACY_PUBLIC_SELF_TEST_URL:-}
      YACY_NETWORK_NAME: ${YACY_NETWORK_NAME:-freeworld}
      YACY_SEEDLIST_URLS: >-
        http://sixcooler.de/yacy/seed.txt,
        https://sonst.mifritscher.de/yacy/seed.txt,
        http://5.45.105.16/yacyseed,
        http://yacy.v16.de/seed/seed.txt,
        https://frank-siebert.de/seed.txt,
        http://seedlist.wertewesten.net/seed.txt
      NATS_URL: nats://nats:4222
      YACY_PROXY_URL: http://smokescreen:4750
      YAGO_SEARCH_API_KEY: ${YAGO_SEARCH_API_KEY:-}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}
    volumes:
      - yacy-data:/data

  smokescreen:
    image: pretix/smokescreen:latest
    restart: unless-stopped
    command: ["--listen-ip", "0.0.0.0"]

  yacycrawler:
    build:
      context: .
      dockerfile: yacycrawler/Dockerfile
    image: yacycrawler:latest
    restart: unless-stopped
    depends_on:
      - nats
      - smokescreen
    environment:
      NATS_URL: nats://nats:4222
      YACYCRAWLER_PROXY_URL: http://smokescreen:4750
      YACYCRAWLER_MAX_REDIRECTS: ${YACYCRAWLER_MAX_REDIRECTS:-10}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}

volumes:
  yacy-data:
