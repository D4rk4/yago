{
  "title": "Pipeline overview",
  "uid": "pipeline-overview",
  "editable": true,
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "title": "Crawl orders placed from user visits",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "targets": [
        { "expr": "rate(yacyvisitcrawl_orders_placed_total[5m])", "legendFormat": "placed" },
        { "expr": "rate(yacyvisitcrawl_orders_unplaced_total[5m])", "legendFormat": "unplaced" }
      ]
    },
    {
      "title": "Pages processed by the crawler",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "targets": [
        { "expr": "rate(yacycrawler_pages_fetched_total[5m])", "legendFormat": "fetched" },
        { "expr": "rate(yacycrawler_pages_published_total[5m])", "legendFormat": "published {{output}}" },
        { "expr": "rate(yacycrawler_pages_disposed_total[5m])", "legendFormat": "disposed {{reason}}" }
      ]
    },
    {
      "title": "Crawl orders processed by the crawler",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "targets": [
        { "expr": "rate(yacycrawler_orders_received_total[5m])", "legendFormat": "received" },
        { "expr": "rate(yacycrawler_orders_completed_total[5m])", "legendFormat": "completed" },
        { "expr": "rate(yacycrawler_orders_redelivered_total[5m])", "legendFormat": "redelivered" }
      ]
    },
    {
      "title": "Pages indexed into the search engine",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "targets": [
        { "expr": "rate(yacytextindexer_pages_indexed_total[5m])", "legendFormat": "indexed" },
        { "expr": "rate(yacytextindexer_pages_received_total[5m])", "legendFormat": "received" },
        { "expr": "rate(yacytextindexer_index_failures_total[5m])", "legendFormat": "failures" }
      ]
    },
    {
      "title": "Pages rendered for the crawler",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "targets": [
        { "expr": "rate(renderproxy_renders_succeeded_total[5m])", "legendFormat": "succeeded" },
        { "expr": "rate(renderproxy_renders_failed_total[5m])", "legendFormat": "failed {{reason}}" }
      ]
    },
    {
      "title": "Peer storage used against its quota",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "storage_used_bytes", "legendFormat": "used" },
        { "expr": "storage_quota_bytes", "legendFormat": "quota" }
      ]
    }
  ]
}
