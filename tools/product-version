#!/bin/sh
set -eu

tag=$(git describe --tags --exact-match HEAD 2>/dev/null || true)
state=$(git status --porcelain --untracked-files=normal 2>/dev/null || true)
if printf '%s\n' "$tag" | grep -Eq '^v(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)$' &&
	[ -z "$state" ]; then
	printf '%s' "$tag"
else
	date -u +%Y.%m.%d-dev
fi
