# yago-crawler environment for the systemd unit. Copy to
# /opt/yago/etc/yago-crawler.env and edit. Full reference: docker-compose.yml.example.

# The node's crawl RPC endpoint. Required.
YAGO_CRAWLER_NODE_RPC_ADDR=127.0.0.1:9091

YAGO_DATA_DIR=/opt/yago/data

YAGO_CRAWLER_WORKER_ID=

YAGO_CRAWLER_WORKERS=4
YAGO_CRAWLER_PRIORITIZE_AUTOMATIC_DISCOVERY=true
YAGO_CRAWLER_MAX_HOST_CONCURRENCY=2
YAGO_CRAWLER_MAX_DEPTH=2
YAGO_CRAWLER_MAX_PAGES_PER_RUN=50000
YAGO_CRAWLER_STORAGE_RESERVED_FREE=1GB
YAGO_CRAWLER_STORAGE_PRESSURE_HYSTERESIS=256MB
YAGO_CRAWLER_CRAWL_DELAY=500ms
YAGO_CRAWLER_USER_AGENT=

YAGO_CRAWLER_METRICS_ADDR=
YAGO_CRAWLER_SHUTDOWN_GRACE=10s

YAGO_CRAWLER_ALLOW_PRIVATE_NETWORKS=false
YAGO_CRAWLER_ALLOW_CIDRS=

YAGO_CRAWLER_REQUEST_TIMEOUT=15s
YAGO_CRAWLER_CONNECT_TIMEOUT=5s
YAGO_CRAWLER_TLS_TIMEOUT=5s
YAGO_CRAWLER_HEADER_TIMEOUT=10s
YAGO_CRAWLER_MAX_REDIRECTS=10
YAGO_CRAWLER_SITEMAP_URL_LIMIT=10000

YAGO_CRAWLER_BROWSER_PATH=

# Keep Firefox's own content sandbox off unless this host grants unprivileged
# user namespaces and the unit relaxes NoNewPrivileges; see deploy/README.md.
YAGO_CRAWLER_BROWSER_SANDBOX=false

YAGO_CRAWLER_BROWSER_FAILURE_THRESHOLD=5

LOG_LEVEL=INFO

# Default fetch pace per crawl run, pages per minute (0 = unlimited). Every run
# starts at this polite pace; the admin console's crawl monitor can raise or
# zero a running crawl's rate per run.
YAGO_CRAWLER_RUN_PAGES_PER_MINUTE=30
