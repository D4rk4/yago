# yagocrawler environment for the systemd unit. Copy to
# /opt/yago/etc/yagocrawler.env and edit. Full reference: docker-compose.yml.example.

# The node's crawl RPC endpoint. Required.
YAGOCRAWLER_NODE_RPC_ADDR=127.0.0.1:9091

# Slow-path browser. On bare metal, point at the OS browser installed as a
# package dependency (chromium or google-chrome-stable). Empty falls back to
# discovery on PATH, which suits the container image's bundled headless-shell.
YAGOCRAWLER_BROWSER_PATH=/usr/bin/chromium

# Keep Chrome's own renderer sandbox off unless this host grants unprivileged
# user namespaces and the unit relaxes NoNewPrivileges; see deploy/README.md.
YAGOCRAWLER_BROWSER_SANDBOX=false

LOG_LEVEL=INFO
