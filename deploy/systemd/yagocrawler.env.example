# yagocrawler environment for the systemd unit. Copy to
# /opt/yago/etc/yagocrawler.env and edit. Full reference: docker-compose.yml.example.

# The node's crawl RPC endpoint. Required.
YAGOCRAWLER_NODE_RPC_ADDR=127.0.0.1:9091

YAGOCRAWLER_WORKER_ID=

YAGOCRAWLER_WORKERS=4
YAGOCRAWLER_MAX_HOST_CONCURRENCY=2
YAGOCRAWLER_MAX_DEPTH=2
YAGOCRAWLER_MAX_PAGES_PER_RUN=50000
YAGOCRAWLER_CRAWL_DELAY=500ms
YAGOCRAWLER_USER_AGENT=

YAGOCRAWLER_METRICS_ADDR=
YAGOCRAWLER_SHUTDOWN_GRACE=10s

YAGOCRAWLER_ALLOW_PRIVATE_NETWORKS=false
YAGOCRAWLER_ALLOW_CIDRS=

YAGOCRAWLER_REQUEST_TIMEOUT=15s
YAGOCRAWLER_CONNECT_TIMEOUT=5s
YAGOCRAWLER_TLS_TIMEOUT=5s
YAGOCRAWLER_HEADER_TIMEOUT=10s
YAGOCRAWLER_MAX_REDIRECTS=10
YAGOCRAWLER_SITEMAP_URL_LIMIT=10000

YAGOCRAWLER_BROWSER_PATH=

# Keep Firefox's own content sandbox off unless this host grants unprivileged
# user namespaces and the unit relaxes NoNewPrivileges; see deploy/README.md.
YAGOCRAWLER_BROWSER_SANDBOX=false

YAGOCRAWLER_BROWSER_FAILURE_THRESHOLD=5

LOG_LEVEL=INFO

# Default fetch pace per crawl run, pages per minute (0 = unlimited). Every run
# starts at this polite pace; the admin console's crawl monitor can raise or
# zero a running crawl's rate per run.
YAGOCRAWLER_RUN_PAGES_PER_MINUTE=30
