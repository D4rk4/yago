# yagocrawler environment for the systemd unit. Copy to
# /opt/yago/etc/yagocrawler.env and edit. Full reference: docker-compose.yml.example.

# The node's crawl RPC endpoint. Required.
YAGOCRAWLER_NODE_RPC_ADDR=127.0.0.1:9091

# Slow-path browser: headless Firefox, driven over Marionette. On bare metal,
# point at the OS browser installed as a package dependency (firefox-esr, or
# firefox). Empty falls back to discovery on PATH (firefox-esr, then firefox),
# which suits the container image's bundled firefox-esr.
YAGOCRAWLER_BROWSER_PATH=/usr/bin/firefox-esr

# Keep Firefox's own content sandbox off unless this host grants unprivileged
# user namespaces and the unit relaxes NoNewPrivileges; see deploy/README.md.
YAGOCRAWLER_BROWSER_SANDBOX=false

# After this many consecutive browser malfunctions (a launch failure, a dead
# process, a navigation timeout), the crawler stops relaunching the browser for a
# cooldown and serves only the HTTP fast path, so an unusable browser cannot spam
# identical failures on every page. A clean non-HTML rejection proves the browser
# is alive and does not count. 0 disables the breaker.
YAGOCRAWLER_BROWSER_FAILURE_THRESHOLD=5

LOG_LEVEL=INFO

# Default fetch pace per crawl run, pages per minute (0 = unlimited). Every run
# starts at this polite pace; the admin console's crawl monitor can raise or
# zero a running crawl's rate per run.
YAGOCRAWLER_RUN_PAGES_PER_MINUTE=30
