# yago-node environment for the systemd unit. Copy to /opt/yago/etc/yago-node.env
# and edit. Full reference: docker-compose.yml.example and yagonode/doc.

# All mutable state (indexes, vaults, generated peer identity) lives here.
YAGO_DATA_DIR=/opt/yago/data

# Public hostname other peers dial. Leave unset to auto-detect the first
# non-loopback IPv4 address; set it explicitly behind NAT or a reverse proxy.
# YAGO_ADVERTISE_HOST=

# Admin console credentials. Unset both to run the first-run setup.
# YAGO_ADMIN_USER=
# YAGO_ADMIN_PASSWORD=

# The crawl-exchange endpoint the local crawler connects to. Defaults to
# 127.0.0.1:9091 (matches yagocrawler's default), so the crawler this package
# installs alongside the node works out of the box. Set "off" for a node with
# no crawler, or ":9091" to accept a crawler running on another host.
# YAGO_CRAWL_RPC_ADDR=127.0.0.1:9091

# Storage quota for the durable vaults.
YAGO_STORAGE_QUOTA=1GB

LOG_LEVEL=INFO
