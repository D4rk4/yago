# yago-node environment for the systemd unit. Copy to /opt/yago/etc/yago-node.env
# and edit. Full reference: docker-compose.yml.example and yagonode/doc.

# All mutable state (indexes, vaults, generated peer identity) lives here.
YAGO_DATA_DIR=/opt/yago/data

# Public hostname other peers dial. Leave unset to auto-detect the first
# non-loopback IPv4 address; set it explicitly behind NAT or a reverse proxy.
# YAGO_ADVERTISE_HOST=

# Admin console credentials. Unset both to run the first-run setup.
# YAGO_ADMIN_USER=
# YAGO_ADMIN_PASSWORD=

# YAGO_CRAWL_RPC_ADDR=127.0.0.1:9091

YAGOCRAWLER_WORKERS=4
YAGO_CRAWLER_PRIORITIZE_AUTOMATIC_DISCOVERY=true

# Peer seed lists that bootstrap the swarm, comma-separated. The first-run setup
# wizard prefills the canonical public seeds; set them here to bootstrap a node
# configured entirely from the environment. Leave unset for a private node.
# YAGO_SEEDLIST_URLS=http://sixcooler.de/yacy/seed.txt,https://sonst.mifritscher.de/yacy/seed.txt,http://5.45.105.16/yacyseed,http://yacy.v16.de/seed/seed.txt,https://frank-siebert.de/seed.txt,http://seedlist.wertewesten.net/seed.txt

# Storage quota for the durable vaults.
YAGO_STORAGE_QUOTA=1GB

YAGO_SEARCH_REMOTE_PEER_TIMEOUT=1200ms
YAGO_SEARCH_REMOTE_TIMEOUT=1300ms

YAGO_SEARCH_API_KEY=

YAGO_WEB_FALLBACK_ENABLED=false
YAGO_WEB_FALLBACK_PRIVACY=
YAGO_SWARM_SEED_CRAWL=true
YAGO_SWARM_SEED_DEPTH=5
YAGO_SWARM_SEED_MAX_PAGES=250
YAGO_WEB_FALLBACK_SEED_CRAWL=false
YAGO_WEB_FALLBACK_SEED_DEPTH=5
YAGO_WEB_FALLBACK_SEED_MAX_PAGES=250

LOG_LEVEL=INFO
