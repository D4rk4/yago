{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Autocrawler</nav>
<h1 class="cds-heading">Autocrawler</h1>
<p class="cds-muted">The autocrawler grows the index without a manual crawl: swarm greedy learning
crawls URLs surfaced by swarm searches until the document limit is reached, and web-discovery
seeding crawls URLs the web-search fallback surfaced. Each path has its own toggle and crawl
profile; crawls stay conservative (domain-scoped) regardless.</p>
{{if .Notice}}<div class="cds-inline-notification cds-inline-notification--success" role="status">{{.Notice}}</div>{{end}}
{{if .Error}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.Error}}</div>{{end}}
{{if .Formats}}
<h2 class="cds-h2">Document formats</h2>
<p class="cds-muted">Format families every crawl parses and indexes (shared by all crawls; YaCy TextParser parity). HTML/web text is always on. Archives are off by default: unpacking hostile archives is a security decision.</p>
{{if .FormatsNote}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.FormatsNote}}</div>{{end}}
<form class="cds-form" method="post" action="/admin/autocrawler/formats" hx-boost="false">
  <input type="hidden" name="csrf_token" value="{{.CSRF}}">
  <fieldset class="cds-field">
    <legend class="cds-label">Enabled families</legend>
    <label class="cds-checkbox"><input type="checkbox" name="text"{{if .Formats.Text}} checked{{end}}> Text (txt, tex, csv, rtf, msg)</label>
    <label class="cds-checkbox"><input type="checkbox" name="xmlfeeds"{{if .Formats.XMLFeeds}} checked{{end}}> XML &amp; feeds (xml, rss, atom)</label>
    <label class="cds-checkbox"><input type="checkbox" name="pdf"{{if .Formats.PDF}} checked{{end}}> PDF &amp; PostScript</label>
    <label class="cds-checkbox"><input type="checkbox" name="office"{{if .Formats.Office}} checked{{end}}> Office (OOXML, OpenDocument, legacy Office, Visio, FreeMind)</label>
    <label class="cds-checkbox"><input type="checkbox" name="images"{{if .Formats.Images}} checked{{end}}> Images (metadata only, no OCR)</label>
    <label class="cds-checkbox"><input type="checkbox" name="audio"{{if .Formats.Audio}} checked{{end}}> Audio (tags only, no transcription)</label>
    <label class="cds-checkbox"><input type="checkbox" name="misc"{{if .Formats.Misc}} checked{{end}}> vCard, torrent, APK</label>
    <label class="cds-checkbox"><input type="checkbox" name="archives"{{if .Formats.Archives}} checked{{end}}> Archives (zip, jar, epub, tar, gz, bz2, xz) — security risk</label>
  </fieldset>
  <button class="cds-btn" type="submit">Save format settings</button>
</form>
{{end}}
{{range .Settings.Items}}
<form class="cds-form" method="post" action="/admin/autocrawler" hx-boost="false">
  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
  <input type="hidden" name="key" value="{{.Key}}">
  <div class="cds-field">
    <label class="cds-label" for="autocrawler-{{.Key}}">{{.Title}}{{if .Overridden}} <span class="cds-tag cds-tag--info">overridden</span>{{end}}</label>
    {{if .Description}}<p class="cds-muted">{{.Description}}</p>{{end}}
    {{if .Options}}
    <select class="cds-input" id="autocrawler-{{.Key}}" name="value">
      {{$current := .Value}}
      {{range .Options}}<option value="{{.Value}}"{{if eq .Value $current}} selected{{end}}>{{.Label}}</option>{{end}}
    </select>
    {{else}}
    <input class="cds-input" type="text" id="autocrawler-{{.Key}}" name="value" value="{{.Value}}" autocomplete="off">
    {{end}}
    {{if .RestartRequired}}<p class="cds-muted">Takes effect after a node restart.</p>{{end}}
  </div>
  <button class="cds-btn" type="submit">Save</button>
  {{if .Overridden}}<button class="cds-btn cds-btn--ghost" type="submit" name="reset" value="true">Reset to default</button>{{end}}
</form>
{{end}}
{{end}}
