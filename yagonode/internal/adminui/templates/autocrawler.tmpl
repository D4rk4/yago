{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Autocrawler</nav>
<h1 class="cds-heading">Autocrawler</h1>
<p class="cds-muted">The autocrawler grows the index without a manual crawl: swarm greedy learning
crawls URLs surfaced by swarm searches while it is enabled, and web-discovery
seeding crawls URLs the web-search fallback surfaced. Each path has its own toggle and crawl
profile; crawls stay conservative (domain-scoped) regardless.</p>
{{if .Notice}}<div class="cds-inline-notification cds-inline-notification--success" role="status">{{.Notice}}</div>{{end}}
{{if .Error}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.Error}}</div>{{end}}
{{if .Settings.Error}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.Settings.Error}}</div>{{end}}
{{if .FormatsOn}}
<h2 class="cds-h2">Document formats</h2>
{{if .FormatsError}}
<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.FormatsError}}</div>
{{else}}
<p class="cds-muted">Format families every crawl parses and indexes (shared by all crawls; YaCy TextParser parity). HTML/web text is always on. Archives are off by default: unpacking hostile archives is a security decision.</p>
{{if .FormatsNote}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.FormatsNote}}</div>{{end}}
{{with .Formats}}
<form class="cds-form" method="post" action="/admin/autocrawler/formats" hx-boost="false">
  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
  <fieldset class="cds-field">
    <legend class="cds-label">Enabled families</legend>
    <label class="cds-checkbox"><input type="checkbox" name="text"{{if .Text}} checked{{end}}> Text (txt, tex, csv, rtf, msg)</label>
    <label class="cds-checkbox"><input type="checkbox" name="xmlfeeds"{{if .XMLFeeds}} checked{{end}}> XML &amp; feeds (xml, rss, atom)</label>
    <label class="cds-checkbox"><input type="checkbox" name="pdf"{{if .PDF}} checked{{end}}> PDF &amp; PostScript</label>
    <label class="cds-checkbox"><input type="checkbox" name="office"{{if .Office}} checked{{end}}> Office (OOXML, OpenDocument, legacy Office, Visio, FreeMind)</label>
    <label class="cds-checkbox"><input type="checkbox" name="images"{{if .Images}} checked{{end}}> Images (metadata only, no OCR)</label>
    <label class="cds-checkbox"><input type="checkbox" name="audio"{{if .Audio}} checked{{end}}> Audio (tags only, no transcription)</label>
    <label class="cds-checkbox"><input type="checkbox" name="misc"{{if .Misc}} checked{{end}}> vCard, torrent, APK</label>
    <label class="cds-checkbox"><input type="checkbox" name="archives"{{if .Archives}} checked{{end}}> Archives (zip, jar, epub, tar, gz, bz2, xz) — security risk</label>
  </fieldset>
  <button class="cds-btn" type="submit">Save format settings</button>
</form>
{{end}}
{{end}}
{{end}}
{{if .Settings.Items}}
<form class="cds-settings-form" method="post" action="/admin/autocrawler" hx-boost="false">
  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
  <fieldset class="cds-fieldset">
    <legend class="cds-legend">Autocrawler settings</legend>
    {{range .Settings.Items}}
    <div class="cds-setting-row"{{if .Description}} title="{{.Description}}"{{end}}>
      <input type="hidden" name="key" value="{{.Key}}">
      <span class="cds-setting-row__label">
        <label for="autocrawler-{{.Key}}">{{.Title}}</label>
        {{if .Overridden}}<span class="cds-tag cds-tag--info">overridden</span>{{end}}
      </span>
      <span class="cds-setting-row__control">
        {{if .Boolean}}
        <input type="hidden" name="bool:{{.Key}}" value="1">
        <label class="cds-checkbox"><input type="checkbox" id="autocrawler-{{.Key}}" name="value:{{.Key}}" value="true"{{if eq .Value "true"}} checked{{end}}> Enabled</label>
        {{else if .Options}}
        <select class="cds-input" id="autocrawler-{{.Key}}" name="value:{{.Key}}">
          {{$current := .Value}}
          {{range .Options}}<option value="{{.Value}}"{{if eq .Value $current}} selected{{end}}>{{.Label}}</option>{{end}}
        </select>
        {{else}}
        <input class="cds-input" type="text" id="autocrawler-{{.Key}}" name="value:{{.Key}}" value="{{.Value}}" autocomplete="off">
        {{end}}
      </span>
    </div>
    {{end}}
  </fieldset>
  <button class="cds-btn" type="submit">Save</button>
</form>
{{end}}
{{end}}
