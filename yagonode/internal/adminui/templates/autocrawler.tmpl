{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Autocrawler</nav>
<h1 class="cds-heading">Autocrawler</h1>
<p class="cds-muted">The autocrawler grows the index without a manual crawl: swarm greedy learning
crawls URLs surfaced by swarm searches until the document limit is reached, and web-discovery
seeding crawls URLs the web-search fallback surfaced. Each path has its own toggle and crawl
profile; crawls stay conservative (domain-scoped) regardless.</p>
{{if .Notice}}<div class="cds-inline-notification cds-inline-notification--success" role="status">{{.Notice}}</div>{{end}}
{{if .Error}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.Error}}</div>{{end}}
{{range .Settings.Items}}
<form class="cds-form" method="post" action="/admin/autocrawler" hx-boost="false">
  <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
  <input type="hidden" name="key" value="{{.Key}}">
  <div class="cds-field">
    <label class="cds-label" for="autocrawler-{{.Key}}">{{.Title}}{{if .Overridden}} <span class="cds-tag cds-tag--info">overridden</span>{{end}}</label>
    {{if .Description}}<p class="cds-muted">{{.Description}}</p>{{end}}
    {{if .Options}}
    <select class="cds-input" id="autocrawler-{{.Key}}" name="value">
      {{$current := .Value}}
      {{range .Options}}<option value="{{.Value}}"{{if eq .Value $current}} selected{{end}}>{{.Label}}</option>{{end}}
    </select>
    {{else}}
    <input class="cds-input" type="text" id="autocrawler-{{.Key}}" name="value" value="{{.Value}}" autocomplete="off">
    {{end}}
    {{if .RestartRequired}}<p class="cds-muted">Takes effect after a node restart.</p>{{end}}
  </div>
  <button class="cds-btn" type="submit">Save</button>
  {{if .Overridden}}<button class="cds-btn cds-btn--ghost" type="submit" name="reset" value="true">Reset to default</button>{{end}}
</form>
{{end}}
{{end}}
