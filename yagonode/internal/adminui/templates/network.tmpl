{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Network</nav>
<h1 class="cds-h1">Network</h1>
{{if .Network.Available}}
<div class="cds-tile-grid">
  <section class="cds-tile">
    <div class="cds-metric__label">Known peers</div>
    <div class="cds-metric__value">{{if .Network.RosterAvailable}}{{.Network.KnownPeers}}{{else}}Unavailable{{end}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Reachable peers</div>
    <div class="cds-metric__value">{{if .Network.RosterAvailable}}{{.Network.ReachablePeers}}{{else}}Unavailable{{end}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">DHT distribution</div>
    <div class="cds-metric__value">{{if .Network.DHTOpen}}Open{{else}}Closed{{end}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Public endpoint self-test</div>
    <div class="cds-metric__value">{{if .Network.PublicReachable}}Reachable{{else}}Unreachable{{end}}</div>
  </section>
</div>
{{if .NetworkSelfTestEnabled}}
<h2 class="cds-h2">Public endpoint self-test</h2>
<p class="cds-muted">Run a fresh bounded YaCy query through the configured public endpoint.</p>
{{if .NetworkSelfTestNotice}}<div class="cds-inline-notification" role="status">{{.NetworkSelfTestNotice}}</div>{{end}}
{{if .NetworkSelfTestError}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.NetworkSelfTestError}}</div>{{end}}
<form method="post" action="/admin/network/public-endpoint/test">
  <input type="hidden" name="csrf_token" value="{{.CSRF}}">
  <button class="cds-btn" type="submit">Run self-test</button>
</form>
{{end}}
{{if and (not .Network.DHTOpen) .Network.BlockingReason}}
<div class="cds-inline-notification" role="status">DHT distribution gate closed: {{.Network.BlockingReason}}</div>
{{end}}
{{if .Network.OwnFlags}}
<h2 class="cds-h2">Advertised to swarm</h2>
<p>Capability flags this node publishes in its seed (hello, seed lists): peers read them to decide what to send us.</p>
<p>
  {{range .Network.OwnFlags}}
  {{if .Set}}<span class="cds-tag cds-tag--success">{{.Name}}: on</span>{{else}}<span class="cds-tag">{{.Name}}: off</span>{{end}}
  {{end}}
</p>
{{end}}
<h2 class="cds-h2">DHT gates</h2>
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr><th scope="col">Gate</th><th scope="col">State</th><th scope="col">Reason</th></tr></thead>
    <tbody>
      {{range .Network.Gates}}
      <tr>
        <th scope="row">{{.Name}}</th>
        <td>{{if .Open}}<span class="cds-tag">open</span>{{else}}closed{{end}}</td>
        <td>{{if .Reason}}{{.Reason}}{{else}}—{{end}}</td>
      </tr>
      {{else}}
      <tr><td colspan="3">No gate data.</td></tr>
      {{end}}
    </tbody>
  </table>
</div>
<h2 class="cds-h2" id="peers">Peers</h2>
{{if not .Network.RosterAvailable}}
<div class="cds-inline-notification cds-inline-notification--error" role="alert">Peer roster is unavailable.</div>
{{else if .PeerTable.Total}}
{{$t := .PeerTable}}
{{$links := .PeerLinks}}
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr>
      <th scope="col" aria-sort="{{$t.ColumnAriaSort "name"}}"><a href="{{$t.ColumnURL "name"}}">Peer{{with $t.ColumnIndicator "name"}} {{.}}{{end}}</a></th>
      <th scope="col" aria-sort="{{$t.ColumnAriaSort "type"}}"><a href="{{$t.ColumnURL "type"}}">Type{{with $t.ColumnIndicator "type"}} {{.}}{{end}}</a></th>
      <th scope="col" aria-sort="{{$t.ColumnAriaSort "address"}}"><a href="{{$t.ColumnURL "address"}}">Address{{with $t.ColumnIndicator "address"}} {{.}}{{end}}</a></th>
      <th scope="col">Flags</th>
      <th scope="col" aria-sort="{{$t.ColumnAriaSort "rwi"}}"><a href="{{$t.ColumnURL "rwi"}}">RWI count{{with $t.ColumnIndicator "rwi"}} {{.}}{{end}}</a></th>
      <th scope="col" aria-sort="{{$t.ColumnAriaSort "lastseen"}}"><a href="{{$t.ColumnURL "lastseen"}}">Last seen{{with $t.ColumnIndicator "lastseen"}} {{.}}{{end}}</a></th>
      <th scope="col" aria-sort="{{$t.ColumnAriaSort "health"}}"><a href="{{$t.ColumnURL "health"}}">Health{{with $t.ColumnIndicator "health"}} {{.}}{{end}}</a></th>
      <th scope="col" aria-sort="{{$t.ColumnAriaSort "age"}}"><a href="{{$t.ColumnURL "age"}}">Age (days){{with $t.ColumnIndicator "age"}} {{.}}{{end}}</a></th>
      <th scope="col">Hash</th>
    </tr></thead>
    <tbody>
      {{range $t.Peers}}
      <tr>
        <th scope="row">{{if $links}}<a href="/admin/network/peer?hash={{.Hash}}">{{if .Name}}{{.Name}}{{else}}{{.Hash}}{{end}}</a>{{else if .Name}}{{.Name}}{{else}}—{{end}}{{if .BlockStatusKnown}}{{if .Blocked}} <span class="cds-tag cds-tag--error">blocked</span>{{end}}{{else}} <span class="cds-tag cds-tag--debug">block status unavailable</span>{{end}}</th>
        <td>{{if .Type}}{{.Type}}{{else}}—{{end}}</td>
        <td>{{if .Address}}{{.Address}}{{else}}—{{end}}</td>
        <td>{{range .Flags}}<span class="cds-tag cds-tag--info">{{.}}</span> {{else}}—{{end}}</td>
        <td>{{if .RWIKnown}}{{.RWICount}}{{else}}—{{end}}</td>
        <td>{{if .LastSeen}}{{.LastSeen}}{{else}}—{{end}}</td>
        <td>{{if .HealthKnown}}<span class="cds-tag cds-tag--{{if eq .HealthTag "healthy"}}info{{else if eq .HealthTag "aging"}}warn{{else}}error{{end}}">{{.Health}} {{.HealthTag}}</span>{{else}}—{{end}}</td>
        <td>{{if .AgeKnown}}{{.AgeDays}}{{else}}—{{end}}</td>
        <td class="cds-mono">{{.Hash}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
</div>
{{if gt $t.Pages 1}}
<nav class="cds-pager" aria-label="Peer pages">
  {{if $t.HasPrev}}<a rel="prev" href="{{$t.PrevURL}}">‹ Previous</a>{{end}}
  <span class="cds-muted">Page {{$t.Page}} of {{$t.Pages}} · peers {{$t.Start}}–{{$t.End}} of {{$t.Total}}</span>
  {{if $t.HasNext}}<a rel="next" href="{{$t.NextURL}}">Next ›</a>{{end}}
</nav>
{{end}}
{{else}}
<div class="cds-empty" role="status">No peers yet.</div>
{{end}}
<h2 class="cds-h2">Seedlists</h2>
{{if .Network.Seedlists}}
<p class="cds-muted">Bootstrap seedlist URLs imported at startup to discover peers.</p>
{{$refresh := .SeedlistRefresh}}
{{$csrf := .CSRF}}
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr><th scope="col">Seedlist URL</th><th scope="col">Last import</th><th scope="col">Result</th>{{if $refresh}}<th scope="col">Action</th>{{end}}</tr></thead>
    <tbody>
      {{range .Network.Seedlists}}
      <tr>
        <td class="cds-mono">{{.URL}}</td>
        <td>{{if and .StatusKnown .Imported}}{{.LastImport}}{{else}}—{{end}}</td>
        <td>{{if not .StatusKnown}}<span class="cds-tag cds-tag--error">Unavailable</span>{{else if .Imported}}<span class="cds-tag cds-tag--{{if .OK}}success{{else}}error{{end}}">{{.Result}}</span>{{else}}<span class="cds-muted">never</span>{{end}}</td>
        {{if $refresh}}
        <td>
          <form method="post" action="/admin/network/seedlist/refresh">
            <input type="hidden" name="csrf_token" value="{{$csrf}}">
            <input type="hidden" name="url" value="{{.URL}}">
            <button class="cds-btn cds-btn--ghost" type="submit">Refresh now</button>
          </form>
        </td>
        {{end}}
      </tr>
      {{end}}
    </tbody>
  </table>
</div>
{{else}}
<div class="cds-empty" role="status">No seedlist URLs configured.</div>
{{end}}
{{if .PeerNewsEnabled}}
<h2 class="cds-h2">Peer news</h2>
<p class="cds-muted">Recent news records received from other peers, newest first.</p>
{{if not .PeerNewsAvailable}}
<div class="cds-inline-notification cds-inline-notification--error" role="alert">Peer news is unavailable.</div>
{{else if .PeerNews}}
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr><th scope="col">Category</th><th scope="col">Originator</th><th scope="col">Age</th><th scope="col">Detail</th></tr></thead>
    <tbody>
      {{range .PeerNews}}
      <tr>
        <td>{{if .Category}}<span class="cds-tag cds-tag--info">{{.Category}}</span>{{else}}—{{end}}</td>
        <td class="cds-mono">{{.Originator}}</td>
        <td>{{if .Age}}{{.Age}}{{else}}—{{end}}</td>
        <td>{{if .Detail}}{{.Detail}}{{else}}—{{end}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
</div>
{{else}}
<div class="cds-empty" role="status">No peer news received yet.</div>
{{end}}
{{end}}
{{else}}
<div class="cds-empty" role="status" aria-live="polite">Network status is not available.</div>
{{end}}
{{end}}
