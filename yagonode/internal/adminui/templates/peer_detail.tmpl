{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / <a href="/admin/network">Network</a> / Peer</nav>
<h1 class="cds-h1">{{if .Peer.Name}}{{.Peer.Name}}{{else}}Peer{{end}}{{if and .Peer.BlockStatusKnown .Peer.Blocked}} <span class="cds-tag cds-tag--error">blocked</span>{{end}}</h1>
<p class="cds-muted">Read-only view of the peer's published profile as advertised in its seed DNA.</p>
{{if not .Peer.BlockStatusKnown}}
<div class="cds-inline-notification cds-inline-notification--error" role="alert">Block status is unavailable.</div>
{{end}}

{{if .BlockEnabled}}
<div class="cds-actions">
  {{if .Peer.Blocked}}
  <p class="cds-muted">This peer is excluded from index fan-out and from the peer lists this node advertises.</p>
  <form method="post" action="/admin/network/peer/block">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <input type="hidden" name="hash" value="{{.Peer.Hash}}">
    <input type="hidden" name="action" value="unblock">
    <button class="cds-btn" type="submit">Unblock peer</button>
  </form>
  {{else}}
  <form method="post" action="/admin/network/peer/block" hx-confirm="Block this peer? It will be excluded from index fan-out and seeding.">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <input type="hidden" name="hash" value="{{.Peer.Hash}}">
    <input type="hidden" name="action" value="block">
    <button class="cds-btn cds-btn--danger" type="submit">Block peer</button>
  </form>
  {{end}}
</div>
{{end}}

<h2 class="cds-h2">Identity</h2>
<div class="cds-scroll-x">
  <table class="cds-table">
    <tbody>
      <tr><th scope="row">Name</th><td>{{if .Peer.Name}}{{.Peer.Name}}{{else}}—{{end}}</td></tr>
      <tr><th scope="row">Hash</th><td class="cds-mono">{{.Peer.Hash}}</td></tr>
      <tr><th scope="row">Address</th><td>{{if .Peer.Address}}{{.Peer.Address}}{{else}}—{{end}}</td></tr>
      <tr><th scope="row">Type</th><td>{{if .Peer.Type}}{{.Peer.Type}}{{else}}—{{end}}</td></tr>
      <tr><th scope="row">Version</th><td>{{if .Peer.Version}}{{.Peer.Version}}{{else}}—{{end}}</td></tr>
      <tr><th scope="row">Flags</th><td>{{range .Peer.Flags}}<span class="cds-tag cds-tag--info">{{.}}</span> {{else}}—{{end}}</td></tr>
      <tr><th scope="row">Last seen</th><td>{{if .Peer.LastSeen}}{{.Peer.LastSeen}}{{else}}—{{end}}</td></tr>
      <tr><th scope="row">Age (days)</th><td>{{if .Peer.AgeKnown}}{{.Peer.AgeDays}}{{else}}—{{end}}</td></tr>
      <tr><th scope="row">Uptime (minutes)</th><td>{{if .Peer.UptimeKnown}}{{.Peer.UptimeMinutes}}{{else}}—{{end}}</td></tr>
    </tbody>
  </table>
</div>

<h2 class="cds-h2">Statistics</h2>
<div class="cds-tile-grid">
  <section class="cds-tile">
    <div class="cds-metric__label">RWI words</div>
    <div class="cds-metric__value">{{if .Peer.RWIWordsKnown}}{{.Peer.RWIWords}}{{else}}—{{end}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">URLs</div>
    <div class="cds-metric__value">{{if .Peer.URLsKnown}}{{.Peer.URLs}}{{else}}—{{end}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Known seeds</div>
    <div class="cds-metric__value">{{if .Peer.KnownSeedsKnown}}{{.Peer.KnownSeeds}}{{else}}—{{end}}</div>
  </section>
</div>

<h2 class="cds-h2">Index transfer</h2>
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr><th scope="col">Direction</th><th scope="col">Words</th><th scope="col">URLs</th></tr></thead>
    <tbody>
      <tr><th scope="row">Sent</th><td class="cds-mono">{{if .Peer.SentWordsKnown}}{{.Peer.SentWords}}{{else}}—{{end}}</td><td class="cds-mono">{{if .Peer.SentURLsKnown}}{{.Peer.SentURLs}}{{else}}—{{end}}</td></tr>
      <tr><th scope="row">Received</th><td class="cds-mono">{{if .Peer.ReceivedWordsKnown}}{{.Peer.ReceivedWords}}{{else}}—{{end}}</td><td class="cds-mono">{{if .Peer.ReceivedURLsKnown}}{{.Peer.ReceivedURLs}}{{else}}—{{end}}</td></tr>
    </tbody>
  </table>
</div>

<p><a class="cds-btn cds-btn--ghost" href="/admin/network">Back to Network</a></p>
{{end}}
