{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Activity</nav>
<h1 class="cds-h1">Search activity</h1>
{{if eq .Activity.Mode "aggregate"}}
<p class="cds-muted">Privacy mode <strong>aggregate</strong>: only query shapes are recorded — never the text. Switch <code>search.query.log</code> to <code>full</code> for query text and top words.</p>
{{else}}
<p class="cds-muted">Privacy mode <strong>full</strong>: query text is recorded in memory only and wiped on restart.</p>
{{end}}
<div class="cds-tile-grid" role="group" aria-label="Search activity totals">
  <section class="cds-tile">
    <div class="cds-metric__label">Search attempts since start</div>
    <div class="cds-metric__value">{{.Activity.Total}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Confirmed zero-result searches</div>
    <div class="cds-metric__value">{{.Activity.ConfirmedZeroResults}}</div>
  </section>
</div>
{{if .Activity.TopWords}}
<h2 class="cds-h2">Top query words from up to 200 retained recent search attempts</h2>
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr><th scope="col">Word</th><th scope="col">Occurrences</th></tr></thead>
    <tbody>
      {{range .Activity.TopWords}}<tr><td>{{.Word}}</td><td>{{.Count}}</td></tr>{{end}}
    </tbody>
  </table>
</div>
{{end}}
<h2 class="cds-h2">Recent searches</h2>
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr><th scope="col">Time (UTC)</th>{{if eq .Activity.Mode "full"}}<th scope="col">Query</th>{{end}}<th scope="col">Length</th><th scope="col">Terms</th><th scope="col">Search-window upper bound</th><th scope="col">Took</th><th scope="col">Scope</th></tr></thead>
    <tbody>
      {{$full := eq .Activity.Mode "full"}}
      {{range .Activity.Entries}}
      <tr>
        <td class="cds-mono">{{.Time}}</td>
        {{if $full}}<td>{{.Query}}</td>{{end}}
        <td>{{.Length}}</td>
        <td>{{.Terms}}</td>
        <td>{{if .ResultsKnown}}Up to {{.Results}}{{if not .Complete}} (partial){{end}}{{else}}Unavailable{{end}}</td>
        <td class="cds-mono">{{.Duration}}</td>
        <td>{{.Source}}</td>
      </tr>
      {{else}}
      <tr><td colspan="{{if $full}}7{{else}}6{{end}}">No searches recorded yet.</td></tr>
      {{end}}
    </tbody>
  </table>
</div>
{{end}}
