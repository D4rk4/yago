{{define "crawl-monitor"}}
<div id="crawl-monitor" hx-get="/admin/crawl/monitor" hx-trigger="every 5s"
     hx-swap="outerHTML" role="region" aria-label="Crawl monitor">
  <h2 class="cds-h2">Crawl monitor</h2>
  <p>
    <button class="cds-btn cds-btn--ghost" type="button"
            hx-get="/admin/crawl/monitor" hx-target="#crawl-monitor" hx-swap="outerHTML">Refresh</button>
    <span class="cds-muted">order queue: {{.Monitor.QueuePending}} pending, {{.Monitor.QueueLeased}} leased — updates every 5s</span>
  </p>
  <div class="cds-tile-grid" role="group" aria-label="Crawl results and rejections">
    <section class="cds-tile">
      <div class="cds-metric__label">Fetched</div>
      <div class="cds-metric__value">{{.Monitor.Totals.Fetched}}</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">Indexed</div>
      <div class="cds-metric__value">{{.Monitor.Totals.Indexed}}</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">Failed</div>
      <div class="cds-metric__value">{{.Monitor.Totals.Failed}}</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">Robots-denied</div>
      <div class="cds-metric__value">{{.Monitor.Totals.RobotsDenied}}</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">Duplicates</div>
      <div class="cds-metric__value">{{.Monitor.Totals.Duplicates}}</div>
    </section>
    {{if .Health.HarvestRate}}
    <section class="cds-tile">
      <div class="cds-metric__label">Harvest rate</div>
      <div class="cds-metric__value">{{.Health.HarvestRate}}</div>
      <div class="cds-muted">indexed / fetched</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">Link redundancy</div>
      <div class="cds-metric__value">{{.Health.LinkRedundancy}}</div>
      <div class="cds-muted">repeat links / links seen</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">Failure rate</div>
      <div class="cds-metric__value">{{.Health.FailRate}}</div>
      <div class="cds-muted">failed / fetched</div>
    </section>
    {{end}}
  </div>
  {{range .Health.Suspects}}
  <p class="cds-inline-notification cds-inline-notification--warn" role="alert">{{.}}</p>
  {{end}}
  <div class="cds-scroll-x">
    <table class="cds-table">
      <thead>
        <tr>
          <th scope="col">Profile</th>
          <th scope="col">State</th>
          <th scope="col">Fetched</th>
          <th scope="col">Indexed</th>
          <th scope="col">Failed</th>
          <th scope="col">Robots</th>
          <th scope="col">Duplicates</th>
          <th scope="col">Pending</th>
          <th scope="col">Runtime</th>
          {{if .Controllable}}<th scope="col">Actions</th>{{end}}
        </tr>
      </thead>
      <tbody>
        {{$root := .}}
        {{range .Monitor.Runs}}
        <tr>
          <td>{{.Profile}}</td>
          <td><span class="cds-tag{{with stateTag .State}} cds-tag--{{.}}{{end}}">{{.State}}</span></td>
          <td class="cds-mono">{{.Fetched}}</td>
          <td class="cds-mono">{{.Indexed}}</td>
          <td class="cds-mono">{{.Failed}}</td>
          <td class="cds-mono">{{.RobotsDenied}}</td>
          <td class="cds-mono">{{.Duplicates}}</td>
          <td class="cds-mono">{{.Pending}}</td>
          <td class="cds-mono">{{.Runtime}}</td>
          {{if $root.Controllable}}
          <td>
            {{if eq .State "running"}}
            <div class="cds-control-row">
              <form method="post" action="/admin/crawl/control" hx-boost="false" class="cds-inline-form">
                <input type="hidden" name="csrf_token" value="{{$root.CSRF}}">
                <input type="hidden" name="runId" value="{{.RunID}}">
                <button class="cds-btn cds-btn--ghost" type="submit" name="action" value="pause">Pause</button>
                <button class="cds-btn cds-btn--ghost" type="submit" name="action" value="resume">Resume</button>
                <button class="cds-btn cds-btn--danger" type="submit" name="action" value="cancel"
                        hx-post="/admin/crawl/control" hx-include="closest form"
                        hx-target="#crawl-monitor" hx-swap="outerHTML"
                        hx-confirm="Cancel this crawl run? Pending pages are dropped; in-flight fetches finish.">Cancel</button>
              </form>
              <form method="post" action="/admin/crawl/control" hx-boost="false" class="cds-inline-form">
                <input type="hidden" name="csrf_token" value="{{$root.CSRF}}">
                <input type="hidden" name="runId" value="{{.RunID}}">
                <input type="hidden" name="action" value="set_rate">
                <input class="cds-input cds-input--rate" type="number" name="ppm" min="0" step="1"
                       {{if gt .PagesPerMinute 0}}value="{{.PagesPerMinute}}" {{end}}placeholder="pages/min"
                       aria-label="Pages per minute for {{.Profile}}">
                <button class="cds-btn cds-btn--ghost" type="submit">Apply rate</button>
              </form>
            </div>
            {{else}}
            <form method="post" action="/admin/crawl/control" hx-boost="false" class="cds-inline-form">
              <input type="hidden" name="csrf_token" value="{{$root.CSRF}}">
              <input type="hidden" name="runId" value="{{.RunID}}">
              <button class="cds-btn cds-btn--ghost" type="submit" name="action" value="restart"
                      hx-post="/admin/crawl/control" hx-include="closest form"
                      hx-target="#crawl-monitor" hx-swap="outerHTML">Restart</button>
            </form>
            {{end}}
          </td>
          {{end}}
        </tr>
        {{else}}
        <tr><td colspan="{{if .Controllable}}10{{else}}9{{end}}">No crawl runs observed yet.</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}
