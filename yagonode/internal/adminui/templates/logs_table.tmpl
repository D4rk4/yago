{{define "logs-table"}}
<div id="logs-table" hx-get="/admin/logs/events?severity={{.Severity | urlquery}}&amp;category={{.Category | urlquery}}&amp;q={{.Query | urlquery}}&amp;from={{.From | urlquery}}&amp;to={{.To | urlquery}}" hx-trigger="every 10s"
     hx-swap="outerHTML" role="region" aria-label="Recent events">
  {{if .FilterError}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.FilterError}}</div>{{end}}
  <p>
    <button class="cds-btn cds-btn--ghost" type="button"
            hx-get="/admin/logs/events?severity={{.Severity | urlquery}}&amp;category={{.Category | urlquery}}&amp;q={{.Query | urlquery}}&amp;from={{.From | urlquery}}&amp;to={{.To | urlquery}}" hx-target="#logs-table" hx-swap="outerHTML">Refresh</button>
    <span class="cds-muted">updates every 10s{{if or .Severity .Category .Query .From .To}} — filtered{{end}}</span>
  </p>
  <div class="cds-scroll-x">
    <table class="cds-table">
      <thead>
        <tr><th scope="col">Time</th><th scope="col">Severity</th><th scope="col">Category</th><th scope="col">Event</th><th scope="col">Message</th></tr>
      </thead>
      <tbody>
        {{range .Entries}}
        <tr>
          <td class="cds-mono">{{.Time}}</td>
          <td><span class="cds-tag cds-tag--{{.Severity}}">{{.Severity}}</span></td>
          <td>{{.Category}}</td>
          <td>{{.Name}}</td>
          <td>{{.Message}}</td>
        </tr>
        {{else}}
        <tr><td colspan="5">{{if .FilterError}}Correct the UTC time range to view events.{{else if or .Severity .Category .Query .From .To}}No recent events match the current filters.{{else}}No recent events recorded.{{end}}</td></tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}
