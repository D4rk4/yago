{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Index</nav>
<h1 class="cds-h1">Index</h1>
{{if .Index.Available}}
<div class="cds-tile-grid">
  <section class="cds-tile">
    <div class="cds-metric__label">Indexed documents</div>
    <div class="cds-metric__value">{{.Index.Documents}}</div>
  </section>
</div>
<div class="cds-tile">
  <table class="cds-table">
    <tbody>
      <tr><th scope="row">Backend</th><td>{{if .Index.Backend}}{{.Index.Backend}}{{else}}—{{end}}</td></tr>
      <tr><th scope="row">Last updated</th><td>{{if .Index.UpdatedAt}}{{.Index.UpdatedAt}}{{else}}—{{end}}</td></tr>
    </tbody>
  </table>
</div>
{{if .TermEnabled}}
<h2 class="cds-h2">Term browser</h2>
<p class="cds-muted">Look up how many postings a term has in the reverse word index and a sample of the documents that carry it.</p>
<form class="cds-search-form" method="get" action="/admin/index" role="search">
  <input class="cds-input" type="search" name="term" value="{{.Term.Term}}" aria-label="Term" autocomplete="off">
  <button class="cds-btn" type="submit">Look up</button>
</form>
{{if .TermQueried}}
  {{if .Term.Error}}
  <div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.Term.Error}}</div>
  {{else if .Term.NotFound}}
  <p class="cds-muted">No postings for “{{.Term.Term}}” (word hash <span class="cds-mono">{{.Term.Hash}}</span>).</p>
  {{else}}
  <p class="cds-muted">{{.Term.Count}} posting(s) for “{{.Term.Term}}” (word hash <span class="cds-mono">{{.Term.Hash}}</span>). Showing up to {{len .Term.Sample}}.</p>
  <div class="cds-scroll-x">
    <table class="cds-table">
      <thead><tr><th scope="col">Title</th><th scope="col">URL</th></tr></thead>
      <tbody>
        {{range .Term.Sample}}<tr><td>{{if .Title}}{{.Title}}{{else}}—{{end}}</td><td class="cds-mono">{{if .URL}}{{.URL}}{{else}}—{{end}}</td></tr>{{end}}
      </tbody>
    </table>
  </div>
  {{end}}
{{end}}
{{end}}
{{if .DocsEnabled}}
<h2 class="cds-h2">Document browser</h2>
<p class="cds-muted">Search the indexed documents by URL substring and/or domain.</p>
<form class="cds-form cds-form--inline" method="get" action="/admin/index" role="search">
  <div class="cds-field">
    <label class="cds-label" for="q">URL contains</label>
    <input class="cds-input" type="search" id="q" name="q" value="{{.DocQuery}}" autocomplete="off">
  </div>
  <div class="cds-field">
    <label class="cds-label" for="domain">Domain</label>
    <input class="cds-input" type="search" id="domain" name="domain" value="{{.DocDomain}}" autocomplete="off">
  </div>
  <button class="cds-btn" type="submit">Search</button>
  <a class="cds-btn cds-btn--ghost" href="/admin/index">Clear</a>
</form>
{{$del := .DeleteEnabled}}
{{$csrf := .CSRF}}
{{if and $del .DocDomain}}
<form class="cds-actions" method="post" action="/admin/index/delete"
      hx-confirm="Delete every indexed document from {{.DocDomain}}? This cannot be undone.">
  <input type="hidden" name="csrf_token" value="{{$csrf}}">
  <input type="hidden" name="action" value="domain">
  <input type="hidden" name="domain" value="{{.DocDomain}}">
  <button class="cds-btn cds-btn--danger" type="submit">Delete all from {{.DocDomain}}</button>
</form>
{{end}}
{{if .Documents.Documents}}
<p class="cds-muted">{{.Documents.Matched}} matching document(s){{if .Documents.Truncated}}, showing the first {{.Documents.Limit}}{{end}}.</p>
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr><th scope="col">URL</th><th scope="col">Title</th><th scope="col">Type</th><th scope="col">Lang</th><th scope="col">Indexed</th>{{if $del}}<th scope="col">Action</th>{{end}}</tr></thead>
    <tbody>
      {{range .Documents.Documents}}
      <tr>
        <td class="cds-mono">{{.URL}}</td>
        <td>{{if .Title}}{{.Title}}{{else}}—{{end}}</td>
        <td>{{if .ContentType}}{{.ContentType}}{{else}}—{{end}}</td>
        <td>{{if .Language}}{{.Language}}{{else}}—{{end}}</td>
        <td>{{if .IndexedAt}}{{.IndexedAt}}{{else}}—{{end}}</td>
        {{if $del}}
        <td>
          <form method="post" action="/admin/index/delete"
                hx-confirm="Delete this document from the index? This cannot be undone.">
            <input type="hidden" name="csrf_token" value="{{$csrf}}">
            <input type="hidden" name="action" value="url">
            <input type="hidden" name="url" value="{{.Key}}">
            <button class="cds-btn cds-btn--danger cds-btn--ghost" type="submit">Delete</button>
          </form>
        </td>
        {{end}}
      </tr>
      {{end}}
    </tbody>
  </table>
</div>
{{else}}
<div class="cds-empty" role="status">No documents match.</div>
{{end}}
{{end}}
{{if .Schema}}
<h2 class="cds-h2">Index schema</h2>
<p class="cds-muted">Read-only reference of the fields stored in each index.</p>
{{range .Schema}}
<h3 class="cds-h3">{{.Title}}</h3>
<div class="cds-scroll-x">
  <table class="cds-table">
    <thead><tr><th scope="col">Field</th><th scope="col">Description</th></tr></thead>
    <tbody>
      {{range .Fields}}<tr><th scope="row" class="cds-mono">{{.Name}}</th><td>{{.Description}}</td></tr>{{end}}
    </tbody>
  </table>
</div>
{{end}}
{{end}}
{{else}}
<div class="cds-empty" role="status" aria-live="polite">The search index is not available.</div>
{{end}}
{{end}}
