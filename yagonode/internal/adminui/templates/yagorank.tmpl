{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / YagoRank</nav>
<h1 class="cds-h1">YagoRank</h1>
{{template "toasts" .}}
<p class="cds-muted">This page exposes every operator-safe live scoring coefficient. Candidate and evidence windows, the quoted-phrase cap, analyzer confidence, relaxed quorum, RM3 blend, RRF, remote calibration, MMR and per-site caps, and safety and abuse gates remain fixed policy rather than manual controls.</p>
{{if .LearnedModel}}
<section class="cds-settings-form" aria-labelledby="learned-model-heading">
  <h2 class="cds-h2" id="learned-model-heading">Learned model</h2>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label">Active kind</span>
    <span class="cds-setting-row__control"><span class="cds-tag cds-tag--info">{{.LearnedModel.ActiveKind}}</span></span>
  </div>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label">Active revision</span>
    <span class="cds-setting-row__control cds-mono">{{.LearnedModel.ActiveRevision}}</span>
  </div>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label">Rollback</span>
    <span class="cds-setting-row__control">{{if .LearnedModel.RollbackAvailable}}<span class="cds-tag cds-tag--success">Available</span>{{else}}<span class="cds-tag cds-tag--debug">Unavailable</span>{{end}}</span>
  </div>
  <form class="cds-actions cds-control-row" method="post" action="/admin/yagorank" hx-boost="false">
    <input type="hidden" name="csrf_token" value="{{.CSRF}}">
    <button class="cds-btn" type="submit" name="action" value="train-linear"{{if not .ModelTrainingReady}} disabled{{end}} aria-describedby="training-readiness-status">Train linear model</button>
    <button class="cds-btn cds-btn--secondary" type="submit" name="action" value="train-tree"{{if not .ModelTrainingReady}} disabled{{end}} aria-describedby="training-readiness-status">Train tree model</button>
    <button class="cds-btn cds-btn--ghost" type="submit" name="action" value="rollback-model"{{if not .LearnedModel.RollbackAvailable}} disabled{{end}}>Rollback model</button>
  </form>
  <p class="cds-muted" id="training-readiness-status" role="status">{{if .TrainingReadinessAvailable}}{{if .ModelTrainingReady}}Ready{{else}}Not ready{{end}}: {{.TrainingJudgmentCount}} usable judgment{{if ne .TrainingJudgmentCount 1}}s{{end}} across {{.TrainingQueryClusterCount}} independent query cluster{{if ne .TrainingQueryClusterCount 1}}s{{end}}; held-out {{.HeldoutQueryClusterCount}}/{{.MinimumHeldoutQueryClusters}} required.{{else}}Training readiness: Unavailable.{{end}} <a href="/api/admin/v1/search/judgments">Manage judgments through the API</a>.</p>
</section>
{{end}}
{{if .TrainOutcome}}
<section class="cds-settings-form" aria-labelledby="training-outcome-heading">
  <h2 class="cds-h2" id="training-outcome-heading">Training outcome</h2>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label">Promotion</span>
    <span class="cds-setting-row__control">{{if .TrainOutcome.Promoted}}<span class="cds-tag cds-tag--success">Promoted</span>{{else}}<span class="cds-tag cds-tag--warn">Not promoted</span>{{end}}</span>
  </div>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label">Held-out NDCG gain</span>
    <span class="cds-setting-row__control cds-mono">{{printf "%+.4f" .TrainOutcome.HeldOutNDCGGain}}</span>
  </div>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label">Confidence</span>
    <span class="cds-setting-row__control cds-mono">{{printf "%.4f" .TrainOutcome.Confidence}}</span>
  </div>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label">Query split</span>
    <span class="cds-setting-row__control cds-mono">Train {{.TrainOutcome.TrainQueryCount}} / Dev {{.TrainOutcome.DevelopmentQueryCount}} / Test {{.TrainOutcome.TestQueryCount}}</span>
  </div>
  {{if .TrainOutcome.Reasons}}
  <div class="cds-setting-row">
    <span class="cds-setting-row__label">Reasons</span>
    <span class="cds-setting-row__control"><span>{{range .TrainOutcome.Reasons}}{{.}}<br>{{end}}</span></span>
  </div>
  {{end}}
</section>
{{end}}
{{if .Tune}}
<div class="cds-inline-notification cds-inline-notification--success" role="status">
  Tuning preview: mean NDCG@10 {{printf "%.4f" .Tune.BeforeNDCG}} → {{printf "%.4f" .Tune.AfterNDCG}}; {{.Tune.Rounds}} round{{if ne .Tune.Rounds 1}}s{{end}}.
</div>
{{end}}
{{if .HostTrust}}
<form class="cds-settings-form" method="post" action="/admin/yagorank" hx-boost="false" aria-labelledby="host-trust-heading">
  <input type="hidden" name="csrf_token" value="{{.CSRF}}">
  <h2 class="cds-h2" id="host-trust-heading">Host trust</h2>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label"><label for="trust-blend">Trust blend</label></span>
    <span class="cds-setting-row__control">
      <input class="cds-input" type="number" step="any" min="0" max="1" id="trust-blend" name="trust_blend" value="{{.HostTrust.Blend}}" autocomplete="off" inputmode="decimal">
    </span>
  </div>
  <div class="cds-setting-row">
    <span class="cds-setting-row__label"><label for="trust-domains">Trusted domains</label></span>
    <span class="cds-setting-row__control">
      <textarea class="cds-input cds-textarea" id="trust-domains" name="trust_domains" rows="5" autocomplete="off">{{.HostTrust.Domains}}</textarea>
    </span>
  </div>
  <div class="cds-actions">
    <button class="cds-btn" type="submit" name="action" value="save-trust">Save host trust</button>
  </div>
  <p class="cds-muted">{{.HostTrust.DomainCount}} trusted domain{{if ne .HostTrust.DomainCount 1}}s{{end}}</p>
</form>
{{end}}
<form class="cds-settings-form" method="post" action="/admin/yagorank" hx-boost="false">
  <input type="hidden" name="csrf_token" value="{{.CSRF}}">
  {{range .Groups}}
  <fieldset class="cds-fieldset">
    <legend class="cds-legend">{{.Title}}</legend>
    {{range .Weights}}
    <div class="cds-setting-row">
      <span class="cds-setting-row__label"><label for="setting-{{.Key}}">{{.Label}}</label></span>
      <span class="cds-setting-row__control">
        <input class="cds-input" type="number" step="any" min="{{printf "%g" .Minimum}}" max="{{printf "%g" .Maximum}}" id="setting-{{.Key}}" name="{{.Key}}" value="{{printf "%g" .Value}}" autocomplete="off" inputmode="decimal">
        <span class="cds-muted">Default {{printf "%g" .Default}}; allowed {{printf "%g" .Minimum}}–{{printf "%g" .Maximum}}.</span>
        {{if .OutOfRange}}<span class="cds-muted">The active legacy value is outside the allowed range and remains active until this profile is saved.</span>{{end}}
      </span>
    </div>
    {{end}}
  </fieldset>
  {{end}}
  <div class="cds-actions">
    <button class="cds-btn" type="submit" name="action" value="save">Save weights</button>
    <button class="cds-btn cds-btn--ghost" type="submit" name="action" value="tune"{{if or (not .JudgmentsAvailable) (eq .JudgmentCount 0)}} disabled{{end}} aria-describedby="judgment-status">Tune weights</button>
  </div>
  <p class="cds-muted" id="judgment-status" role="status">{{if .JudgmentsAvailable}}{{.JudgmentCount}} judgment{{if ne .JudgmentCount 1}}s{{end}}{{else}}Judgments: Unavailable{{end}}</p>
</form>
{{end}}
