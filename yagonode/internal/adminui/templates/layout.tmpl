{{define "layout"}}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="referrer" content="no-referrer">
<title>{{.Data.Section.Heading}} — {{.Data.AppName}} admin</title>
<link rel="stylesheet" href="/admin/assets/carbon.css">
<link rel="stylesheet" href="/admin/assets/photon.css">
<script src="/admin/assets/htmx.min.js" defer></script>
<script src="/admin/assets/tabs.js" defer></script>
</head>
<body hx-boost="true">
<a class="cds-skip" href="#cds-main">Skip to main content</a>
<svg width="0" height="0" aria-hidden="true" focusable="false" style="position:absolute">
  <symbol id="ic-overview" viewBox="0 0 20 20"><path fill="currentColor" d="M3 3h6v6H3zm8 0h6v6h-6zM3 11h6v6H3zm8 0h6v6h-6z"/></symbol>
  <symbol id="ic-search" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="8.5" cy="8.5" r="5"/><line x1="12.5" y1="12.5" x2="17" y2="17"/></g></symbol>
  <symbol id="ic-activity" viewBox="0 0 20 20"><polyline fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" points="2,11 6,11 8,4 12,16 14,11 18,11"/></symbol>
  <symbol id="ic-autocrawler" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 7A7 7 0 1 0 17.5 11"/><polyline points="16.7,2.6 16.7,7 12.3,7"/></g></symbol>
  <symbol id="ic-crawler" viewBox="0 0 20 20"><g fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><ellipse cx="10" cy="11" rx="3" ry="3.6" stroke="none"/><circle cx="10" cy="6" r="2" stroke="none"/><path fill="none" d="M7 9 3 6M7 11 2.5 11M7 13 3.5 16M13 9 17 6M13 11 17.5 11M13 13 16.5 16"/></g></symbol>
  <symbol id="ic-network" viewBox="0 0 20 20"><g stroke="currentColor" stroke-width="1.4"><line x1="10" y1="4" x2="4" y2="15"/><line x1="10" y1="4" x2="16" y2="15"/><line x1="4" y1="15" x2="16" y2="15"/><circle cx="10" cy="4" r="2.4" fill="currentColor"/><circle cx="4" cy="15" r="2.4" fill="currentColor"/><circle cx="16" cy="15" r="2.4" fill="currentColor"/></g></symbol>
  <symbol id="ic-index" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="10" cy="5" rx="6" ry="2.3"/><path d="M4 5v10c0 1.3 2.7 2.3 6 2.3s6-1 6-2.3V5"/><path d="M4 10c0 1.3 2.7 2.3 6 2.3s6-1 6-2.3"/></g></symbol>
  <symbol id="ic-performance" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 14a7 7 0 0 1 14 0"/><line x1="10" y1="14" x2="13.6" y2="8.4"/></g></symbol>
  <symbol id="ic-yagorank" viewBox="0 0 20 20"><g fill="currentColor"><rect x="3" y="12" width="3" height="5" rx="1"/><rect x="8.5" y="8" width="3" height="9" rx="1"/><rect x="14" y="4" width="3" height="13" rx="1"/></g></symbol>
  <symbol id="ic-configuration" viewBox="0 0 20 20"><g fill="currentColor" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><line x1="3" y1="6" x2="17" y2="6"/><line x1="3" y1="14" x2="17" y2="14"/><circle cx="13" cy="6" r="2.3"/><circle cx="7" cy="14" r="2.3"/></g></symbol>
  <symbol id="ic-security" viewBox="0 0 20 20"><path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" d="M10 2.5 4 5v5c0 4 2.6 6.4 6 7.5 3.4-1.1 6-3.5 6-7.5V5z"/></symbol>
  <symbol id="ic-logs" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><line x1="4" y1="5" x2="16" y2="5"/><line x1="4" y1="9" x2="16" y2="9"/><line x1="4" y1="13" x2="13" y2="13"/><line x1="4" y1="17" x2="16" y2="17"/></g></symbol>
  <symbol id="ic-backup" viewBox="0 0 16 16"><path d="M2 4.5 8 2l6 2.5v7L8 14l-6-2.5v-7zm1.5 1.2v4.9L7.3 12V7.4L3.5 5.7zm9 0L8.7 7.4V12l3.8-1.4V5.7zM8 3.6 4.3 5.1 8 6.7l3.7-1.6L8 3.6z"/></symbol><symbol id="ic-restart" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M15.5 6.5A6.5 6.5 0 1 0 16.8 10.4"/><polyline points="16.2,2.6 16.2,6.8 12,6.8"/></g></symbol>
  <symbol id="ic-globe" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="7"/><ellipse cx="10" cy="10" rx="3" ry="7"/><line x1="3" y1="10" x2="17" y2="10"/><line x1="4.2" y1="6" x2="15.8" y2="6"/><line x1="4.2" y1="14" x2="15.8" y2="14"/></g></symbol>
  <symbol id="ic-logout" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3.5H4.5A1.5 1.5 0 0 0 3 5v10a1.5 1.5 0 0 0 1.5 1.5H8"/><polyline points="12,6.5 15.5,10 12,13.5"/><line x1="15.5" y1="10" x2="7" y2="10"/></g></symbol>
</svg>
<header class="cds-header">
  <a class="cds-header__brand" href="https://github.com/D4rk4/yago" target="_blank" rel="noopener noreferrer" aria-label="yago source on GitHub"><span class="cds-brand__ya">ya</span><span class="cds-brand__go">go</span></a>
  <span class="cds-header__name">admin</span>
  <span class="cds-header__spacer"></span>
  {{if .PublicSearchHref}}<a class="cds-header__link cds-header__icon" href="{{.PublicSearchHref}}" rel="noopener" title="Public search" aria-label="Public search"><svg aria-hidden="true" focusable="false"><use href="#ic-globe"></use></svg></a>{{end}}
  {{if .Data.CSRF}}
  <form class="cds-header__signout" method="post" action="/admin/logout" hx-boost="false">
    <input type="hidden" name="csrf_token" value="{{.Data.CSRF}}">
    <button class="cds-header__link cds-header__button cds-header__icon" type="submit" title="Sign out" aria-label="Sign out"><svg aria-hidden="true" focusable="false"><use href="#ic-logout"></use></svg></button>
  </form>
  {{end}}
</header>
<div class="cds-shell">
  <nav class="cds-nav" aria-label="Sections">
    <ul class="cds-nav__list">
      {{range .Data.Nav}}
      <li><a class="cds-nav__link" href="{{.Path}}"{{if eq .Path $.Data.ActivePath}} aria-current="page"{{end}}><svg class="cds-nav__icon" aria-hidden="true" focusable="false"><use href="#ic-{{.Icon}}"></use></svg><span class="cds-nav__label">{{.Title}}</span></a></li>
      {{end}}
    </ul>
  </nav>
  <main class="cds-main" id="cds-main" tabindex="-1">
    {{template "content" .Data}}
    <footer class="cds-footer">
      {{.Data.AppName}} is free software under the GNU AGPL v3.
      <a href="https://github.com/D4rk4/yago">Source code</a>.
    </footer>
  </main>
</div>
</body>
</html>{{end}}
