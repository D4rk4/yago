{{define "layout"}}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="referrer" content="no-referrer">
<title>{{.Data.Section.Heading}} — {{.Data.AppName}} admin</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="stylesheet" href="{{asset "carbon.css"}}">
<link rel="stylesheet" href="{{asset "photon.css"}}">
<link rel="stylesheet" href="{{asset "photon_shell.css"}}">
<meta name="htmx-config" content='{"includeIndicatorStyles": false}'>
<script src="{{asset "htmx.min.js"}}" defer></script>
<script src="{{asset "tabs.js"}}" defer></script>
</head>
<body hx-boost="true">
<a class="cds-skip" href="#cds-main">Skip to main content</a>
<svg class="cds-icon-sprite" width="0" height="0" aria-hidden="true" focusable="false">
  <symbol id="ic-globe" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="7"/><ellipse cx="10" cy="10" rx="3" ry="7"/><line x1="3" y1="10" x2="17" y2="10"/><line x1="4.2" y1="6" x2="15.8" y2="6"/><line x1="4.2" y1="14" x2="15.8" y2="14"/></g></symbol>
  <symbol id="ic-logout" viewBox="0 0 20 20"><g fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3.5H4.5A1.5 1.5 0 0 0 3 5v10a1.5 1.5 0 0 0 1.5 1.5H8"/><polyline points="12,6.5 15.5,10 12,13.5"/><line x1="15.5" y1="10" x2="7" y2="10"/></g></symbol>
</svg>
<header class="cds-header">
  <a class="cds-header__brand" href="https://github.com/D4rk4/yago" target="_blank" rel="noopener noreferrer" aria-label="yago source on GitHub"><span class="cds-brand__ya">ya</span><span class="cds-brand__go">go</span></a>
  <span class="cds-header__name">admin</span>
  <span class="cds-header__spacer"></span>
  {{if .PublicSearchHref}}<a class="cds-header__link cds-header__icon" href="{{.PublicSearchHref}}" rel="noopener" title="Public search" aria-label="Public search"><svg aria-hidden="true" focusable="false"><use href="#ic-globe"></use></svg></a>{{end}}
  {{if .Data.CSRF}}
  <form class="cds-header__signout" method="post" action="/admin/logout" hx-boost="false">
    <input type="hidden" name="csrf_token" value="{{.Data.CSRF}}">
    <button class="cds-header__link cds-header__button cds-header__icon" type="submit" title="Sign out" aria-label="Sign out"><svg aria-hidden="true" focusable="false"><use href="#ic-logout"></use></svg></button>
  </form>
  {{end}}
</header>
<div class="cds-shell">
  <main class="cds-main" id="cds-main" tabindex="-1">
    {{template "content" .Data}}
    <footer class="cds-footer">
      {{.Data.AppName}} is free software under the GNU AGPL v3.
      <a href="https://github.com/D4rk4/yago">Source code</a>.
    </footer>
  </main>
  <aside class="cds-shelf" aria-label="Administration shelf">
    <nav class="cds-nav" aria-label="Sections">
      <ul class="cds-nav__list">
        {{range .Data.Nav}}
        <li><a class="cds-nav__link" href="{{.Path}}"{{if eq .Path $.Data.ActivePath}} aria-current="page"{{end}}><img class="cds-nav__icon" src="{{asset .Icon}}" width="16" height="16" alt=""><span class="cds-nav__label">{{.Title}}</span></a></li>
        {{end}}
      </ul>
    </nav>
    {{template "system-monitor" .SystemMonitor}}
  </aside>
</div>
</body>
</html>{{end}}
