{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Search</nav>
<h1 class="cds-h1">Search</h1>
<form class="cds-search-form" method="get" action="/admin/search" role="search">
  <div class="cds-field">
    <label class="cds-label" for="q">Query</label>
    {{if .SuggestEnabled}}
    <span class="cds-ac-wrap">
      <input class="cds-input" type="search" id="q" name="q" value="{{.Query}}"
             role="combobox" aria-autocomplete="list" aria-expanded="false"
             aria-controls="ac-list" autocomplete="off" autofocus>
      <ul id="ac-list" class="cds-ac-list" role="listbox" aria-label="Search suggestions" hidden></ul>
    </span>
    {{else}}
    <input class="cds-input" type="search" id="q" name="q" value="{{.Query}}"
           autocomplete="off" autofocus>
    {{end}}
  </div>
  <fieldset class="cds-field">
    <legend class="cds-label">Scope</legend>
    <label class="cds-radio">
      <input type="radio" name="scope" value="global"{{if .Global}} checked{{end}}>
      All enabled sources
    </label>
    <label class="cds-radio">
      <input type="radio" name="scope" value="local"{{if not .Global}} checked{{end}}>
      Local index only
    </label>
  </fieldset>
  <fieldset class="cds-fieldset">
    <legend class="cds-legend">Filters</legend>
    <div class="cds-form cds-form--inline">
      <div class="cds-field">
        <label class="cds-label" for="contentdom">Content domain</label>
        <select class="cds-input" id="contentdom" name="contentdom">
          {{$domain := .Filters.ContentDomain}}
          {{range .ContentDomains}}<option value="{{.Value}}"{{if or (eq .Value $domain) (and (eq $domain "") (eq .Value "text"))}} selected{{end}}>{{.Label}}</option>{{end}}
        </select>
      </div>
      <div class="cds-field">
        <label class="cds-label" for="language">Language</label>
        <input class="cds-input" type="text" id="language" name="language" value="{{.Filters.Language}}" placeholder="for example, en or ru" autocomplete="off">
      </div>
      <div class="cds-field">
        <label class="cds-label" for="sitehost">Site host</label>
        <input class="cds-input" type="text" id="sitehost" name="sitehost" value="{{.Filters.SiteHost}}" placeholder="example.org" autocomplete="off">
      </div>
    </div>
  </fieldset>
  <button class="cds-btn" type="submit">Search</button>
</form>
{{if .ExplainURL}}<p><a href="{{.ExplainURL}}">Explain this ranking in YagoRank</a></p>{{end}}
{{if .Error}}
<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.Error}}</div>
{{else if .Submitted}}
{{with .Results}}
<p class="cds-muted">{{if .TotalResults}}Up to {{.TotalResults}} result(s) available in this search window{{else if .Failures}}No complete result set is available{{else}}0 result(s){{end}} for “{{.Query}}”{{if .Global}} (all enabled sources){{end}}.</p>
{{if .Hint}}<div class="cds-inline-notification" role="status">{{.Hint}}</div>{{end}}
{{range .Failures}}
<div class="cds-inline-notification" role="status">Partial failure: {{.}}</div>
{{end}}
{{range .Results}}
<article class="cds-result">
  <a class="cds-result__title" href="{{.URL}}"{{if $.NewTab}} rel="noopener noreferrer nofollow" target="_blank"{{else}} rel="noreferrer nofollow"{{end}}>
    {{if .Title}}{{.Title}}{{else}}{{.URL}}{{end}}{{if $.NewTab}}<span aria-hidden="true"> ↗</span><span class="cds-sr-only"> (opens in new tab)</span>{{end}}</a>
  <div class="cds-result__url">{{if .DisplayURL}}{{.DisplayURL}}{{else}}{{.URL}}{{end}}{{if .Date}} · {{.Date}}{{end}}{{if .SizeName}} · {{.SizeName}}{{end}}{{if .Source}} · <span class="cds-muted">{{.Source}}</span>{{end}}</div>
  {{if .SnippetHTML}}<p class="cds-result__snippet">{{.SnippetHTML}}</p>{{else if .Snippet}}<p class="cds-result__snippet">{{.Snippet}}</p>{{end}}
</article>
{{else}}
<div class="cds-empty" role="status">{{if .Failures}}No results are currently available; one or more enabled sources failed.{{else}}No results.{{end}}</div>
{{end}}
{{end}}
{{if or .Pagination.HasPrev .Pagination.HasNext}}
<nav class="cds-pager" aria-label="Result pages">
  {{if .Pagination.HasPrev}}<a rel="prev" href="{{.Pagination.PrevURL}}">‹ Previous</a>{{end}}
  <span class="cds-muted">Page {{.Pagination.Page}}</span>
  {{if .Pagination.HasNext}}<a rel="next" href="{{.Pagination.NextURL}}">Next ›</a>{{end}}
</nav>
{{end}}
{{end}}
{{if .SuggestEnabled}}<script src="{{asset "autocomplete.js"}}" defer></script>{{end}}
{{end}}
