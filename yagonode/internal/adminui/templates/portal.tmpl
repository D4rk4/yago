{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Public portal</nav>
<h1 class="cds-heading">Public portal</h1>
<p class="cds-muted">Configure the public search portal and redesign its search and results pages. The Configuration tab gathers the portal-facing settings; the design tabs let an operator edit the public pages without redeploying (ADR-0033).</p>
<div class="cds-tabs" data-tabs>
  <div class="cds-tablist" role="tablist" aria-label="Public portal sections">
    <button type="button" role="tab" class="cds-tab" id="tab-portal-config" aria-controls="panel-portal-config" aria-selected="false">Configuration</button>
    <button type="button" role="tab" class="cds-tab" id="tab-portal-design" aria-controls="panel-portal-design" aria-selected="false">Portal design</button>
    <button type="button" role="tab" class="cds-tab" id="tab-portal-results" aria-controls="panel-portal-results" aria-selected="false">Results design</button>
  </div>

  <section class="cds-tabpanel" role="tabpanel" id="panel-portal-config" aria-labelledby="tab-portal-config">
    <h2 class="cds-h2 cds-tabpanel__heading">Configuration</h2>
    {{if .Notice}}<div class="cds-inline-notification cds-inline-notification--success" role="status">{{.Notice}}</div>{{end}}
    {{if .Error}}<div class="cds-inline-notification cds-inline-notification--error" role="alert">{{.Error}}</div>{{end}}
    {{if .Settings.Items}}
    <form class="cds-settings-form" method="post" action="/admin/portal" hx-boost="false">
      <input type="hidden" name="csrf_token" value="{{$.CSRF}}">
      <fieldset class="cds-fieldset">
        <legend class="cds-legend">Portal settings</legend>
        {{range .Settings.Items}}
        <div class="cds-setting-row"{{if .Description}} title="{{.Description}}"{{end}}>
          <input type="hidden" name="key" value="{{.Key}}">
          <span class="cds-setting-row__label">
            <label for="portal-{{.Key}}">{{.Title}}</label>
            {{if .Overridden}}<span class="cds-tag cds-tag--info">overridden</span>{{end}}
          </span>
          <span class="cds-setting-row__control">
            {{if .Boolean}}
            <input type="hidden" name="bool:{{.Key}}" value="1">
            <label class="cds-checkbox"><input type="checkbox" id="portal-{{.Key}}" name="value:{{.Key}}" value="true"{{if eq .Value "true"}} checked{{end}}> Enabled</label>
            {{else if .Options}}
            <select class="cds-input" id="portal-{{.Key}}" name="value:{{.Key}}">
              {{$current := .Value}}
              {{range .Options}}<option value="{{.Value}}"{{if eq .Value $current}} selected{{end}}>{{.Label}}</option>{{end}}
            </select>
            {{else}}
            <input class="cds-input" type="text" id="portal-{{.Key}}" name="value:{{.Key}}" value="{{.Value}}" autocomplete="off">
            {{end}}
          </span>
        </div>
        {{end}}
      </fieldset>
      <button class="cds-btn" type="submit">Save</button>
    </form>
    {{end}}
  </section>

  <section class="cds-tabpanel" role="tabpanel" id="panel-portal-design" aria-labelledby="tab-portal-design">
    <h2 class="cds-h2 cds-tabpanel__heading">Portal design</h2>
    {{if .DesignSearch}}{{template "design_form" .DesignSearch}}{{else}}
    <p class="cds-muted">The design store is not available on this deployment, so the search-page editor cannot load.</p>
    {{end}}
  </section>

  <section class="cds-tabpanel" role="tabpanel" id="panel-portal-results" aria-labelledby="tab-portal-results">
    <h2 class="cds-h2 cds-tabpanel__heading">Results design</h2>
    {{if .DesignResults}}{{template "design_form" .DesignResults}}{{else}}
    <p class="cds-muted">The design store is not available on this deployment, so the results-page editor cannot load.</p>
    {{end}}
  </section>
</div>
{{if .DesignSearch}}
<link rel="stylesheet" href="/admin/assets/vendor/codemirror.min.css">
<link rel="stylesheet" href="/admin/assets/vendor/grapes.min.css">
<link rel="stylesheet" href="/admin/assets/portal_designer.css">
<script src="/admin/assets/vendor/codemirror.min.js" defer></script>
<script src="/admin/assets/vendor/cm-xml.min.js" defer></script>
<script src="/admin/assets/vendor/cm-javascript.min.js" defer></script>
<script src="/admin/assets/vendor/cm-css.min.js" defer></script>
<script src="/admin/assets/vendor/cm-htmlmixed.min.js" defer></script>
<script src="/admin/assets/vendor/cm-multiplex.min.js" defer></script>
<script src="/admin/assets/vendor/cm-simple.min.js" defer></script>
<script src="/admin/assets/vendor/cm-handlebars.min.js" defer></script>
<script src="/admin/assets/vendor/grapes.min.js" defer></script>
<script src="/admin/assets/vendor/grapesjs-preset-webpage.min.js" defer></script>
<script src="/admin/assets/portal_designer.js?v=4" defer></script>
{{end}}
{{end}}

{{define "design_form"}}
<form class="designer" method="post" action="/admin/portal/design" hx-boost="false" data-designer="{{.Page}}">
  <input type="hidden" name="csrf_token" value="{{.CSRF}}">
  <input type="hidden" name="page" value="{{.Page}}">
  <label class="cds-checkbox"><input type="checkbox" name="enabled" value="true"{{if .Enabled}} checked{{end}}> Use the custom design on the public portal (both pages)</label>
  {{if .Doc.ParseError}}<p class="designer-alert" role="alert">The saved template does not parse: {{.Doc.ParseError}} The public portal keeps serving the previous design.</p>{{end}}
  <div class="designer-toolbar">
    <button type="button" class="designer-toggle cds-btn cds-btn--ghost" hidden>Visual editor</button>
    <p class="designer-hint">Handlebars template for the {{.Label}}. The visual editor works best for layout and chrome; Handlebars block tags survive as text. {{if .Overridden}}This page uses a custom body.{{else}}This page follows the built-in default.{{end}}</p>
  </div>
  <div class="designer-canvas" aria-hidden="true"></div>
  <div class="designer-code">
    <label>Template ({{.Label}})
      <textarea name="body" data-designer-template rows="18" spellcheck="false">{{.Doc.Body}}</textarea>
    </label>
    <label>Shared styles (CSS, used by both pages{{if .StylesOverridden}}, customized{{end}})
      <textarea name="styles" data-designer-styles rows="10" spellcheck="false">{{.Styles.Body}}</textarea>
    </label>
  </div>
  <div class="designer-actions">
    <button class="cds-btn" type="submit">Save design</button>
    {{if .Overridden}}<button class="cds-btn cds-btn--ghost" type="submit" name="action" value="default">Default design</button>{{end}}
    {{if .StylesOverridden}}<button class="cds-btn cds-btn--ghost" type="submit" name="action" value="default-styles">Default styles</button>{{end}}
  </div>
</form>
{{end}}
