{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Performance</nav>
<h1 class="cds-h1">Performance</h1>
{{if .Performance.Available}}
<div class="cds-tile-grid">
  <section class="cds-tile">
    <div class="cds-metric__label">Crawl queue</div>
    <div class="cds-metric__value">{{if .Performance.CrawlQueueKnown}}{{.Performance.CrawlQueueSize}}{{else}}Unavailable{{end}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Index queue</div>
    <div class="cds-metric__value">{{if .Performance.IndexQueueKnown}}{{.Performance.IndexQueueSize}}{{else}}Unavailable{{end}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Connected peers</div>
    <div class="cds-metric__value">{{.Performance.ConnectedPeers}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Local RWI words</div>
    <div class="cds-metric__value">{{if .Performance.LocalRWIKnown}}{{.Performance.LocalRWIWords}}{{else}}Unavailable{{end}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Storage</div>
    <div class="cds-metric__value">{{if not .Performance.StorageKnown}}Unavailable{{else if .Performance.StorageAvailable}}Available{{else}}Full{{end}}</div>
  </section>
</div>
<p class="cds-muted">The crawl queue is the broker's outstanding order backlog, waiting or in flight. The index queue, peer count and storage headroom are read from the DHT gate snapshot. Backup and restore live on the <a href="/admin/backup">Backup &amp; restore</a> page.</p>
{{if .History}}
<h2 class="cds-h2">Recent history</h2>
<div class="cds-tile-grid">
  {{range .History}}
  <section class="cds-tile">
    <div class="cds-metric__label">{{.Name}}</div>
    <div class="cds-metric__value">{{.Latest}}{{if .Unit}} <span class="cds-metric__unit">{{.Unit}}</span>{{end}}</div>
    {{.SVG}}
    <div class="cds-muted cds-sparkline__meta">latest observed {{.ObservedAt}} · peak {{.Peak}}{{if .Unit}} {{.Unit}}{{end}} · {{.Samples}} samples over {{.Window}}</div>
  </section>
  {{end}}
</div>
{{else}}
<p class="cds-muted">History charts appear after the sampler has collected at least two points (about twenty seconds after start).</p>
{{end}}
{{else}}
<div class="cds-empty" role="status" aria-live="polite">Performance metrics are not available.</div>
{{end}}
{{end}}
