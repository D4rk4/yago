{{define "content"}}
<nav class="cds-breadcrumb" aria-label="Breadcrumb"><a href="/admin/overview">Admin</a> / Performance</nav>
<h1 class="cds-h1">Performance</h1>
{{if .Performance.Available}}
<div class="cds-tile-grid">
  <section class="cds-tile">
    <div class="cds-metric__label">Crawl queue</div>
    <div class="cds-metric__value">{{.Performance.CrawlQueueSize}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Index queue</div>
    <div class="cds-metric__value">{{.Performance.IndexQueueSize}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Connected peers</div>
    <div class="cds-metric__value">{{.Performance.ConnectedPeers}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Local RWI words</div>
    <div class="cds-metric__value">{{.Performance.LocalRWIWords}}</div>
  </section>
  <section class="cds-tile">
    <div class="cds-metric__label">Storage</div>
    <div class="cds-metric__value">{{if .Performance.StorageAvailable}}Available{{else}}Full{{end}}</div>
  </section>
</div>
<p class="cds-muted">The crawl queue is the broker's outstanding order backlog, waiting or in flight. The index queue, peer count and storage headroom are read from the DHT gate snapshot. Backup and restore controls are a planned addition.</p>
{{else}}
<div class="cds-empty" role="status" aria-live="polite">Performance metrics are not available.</div>
{{end}}
{{end}}
