{{define "overview-metrics"}}
<div id="overview-metrics" hx-get="/admin/overview/metrics" hx-trigger="every 15s"
     hx-swap="outerHTML" role="region" aria-label="Node status">
  <div class="cds-tile-grid">
    <section class="cds-tile">
      <div class="cds-metric__label">Local indexed documents</div>
      <div class="cds-metric__value">{{if .IndexedDocumentsKnown}}{{.IndexedDocuments}}{{else}}Unavailable{{end}}</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">YaCy URL metadata records</div>
      <div class="cds-metric__value">{{if .URLMetadataRecordsKnown}}{{.URLMetadataRecords}}{{else}}Unavailable{{end}}</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">RWI words</div>
      <div class="cds-metric__value">{{if .WordsKnown}}{{.Words}}{{else}}Unavailable{{end}}</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">Known peers</div>
      <div class="cds-metric__value">{{if .KnownPeersKnown}}{{.KnownPeers}}{{else}}Unavailable{{end}}</div>
    </section>
    <section class="cds-tile">
      <div class="cds-metric__label">Uptime</div>
      <div class="cds-metric__value">{{dur .UptimeSeconds}}</div>
    </section>
  </div>
  <p class="cds-muted">These are separate populations: peer URL metadata can exist without local page content, and locally cached search documents can exist without YaCy URL metadata.</p>
  <div class="cds-tile">
    <h2 class="cds-h2">Identity</h2>
    <table class="cds-table">
      <tbody>
        <tr><th scope="row">Peer name</th><td>{{if .PeerName}}{{.PeerName}}{{else}}—{{end}}</td></tr>
        <tr><th scope="row">Hash</th><td class="cds-mono">{{if .PeerHash}}{{.PeerHash}}{{else}}—{{end}}</td></tr>
        <tr><th scope="row">Type</th><td>{{if .PeerType}}<span class="cds-tag">{{.PeerType}}</span>{{else}}—{{end}}</td></tr>
        <tr><th scope="row">Version</th><td>{{if .Version}}{{.Version}}{{else}}—{{end}}</td></tr>
      </tbody>
    </table>
  </div>
  <div class="cds-tile">
    <h2 class="cds-h2">Index transfer totals</h2>
    <div class="cds-scroll-x">
      <table class="cds-table">
        <thead><tr><th scope="col">Direction</th><th scope="col">Words</th><th scope="col">URLs</th></tr></thead>
        <tbody>
          <tr><th scope="row">Sent</th><td>{{if .SentWordsKnown}}{{.SentWords}}{{else}}Unavailable{{end}}</td><td>{{if .SentURLsKnown}}{{.SentURLs}}{{else}}Unavailable{{end}}</td></tr>
          <tr><th scope="row">Received</th><td>{{if .ReceivedWordsKnown}}{{.ReceivedWords}}{{else}}Unavailable{{end}}</td><td>{{if .ReceivedURLsKnown}}{{.ReceivedURLs}}{{else}}Unavailable{{end}}</td></tr>
        </tbody>
      </table>
    </div>
  </div>
  <p>
    <button class="cds-btn cds-btn--ghost" type="button"
            hx-get="/admin/overview/metrics" hx-target="#overview-metrics" hx-swap="outerHTML">Refresh</button>
  </p>
</div>
{{end}}
