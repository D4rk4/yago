{{define "authstyle"}}<style>
  body { font-family: 'IBM Plex Sans', Arial, Helvetica, sans-serif; background: #f4f4f4; color: #161616; margin: 0; }
  .card { max-width: 22rem; margin: 12vh auto; background: #ffffff; border: 1px solid #e0e0e0; padding: 2rem; }
  h1 { font-size: 1.5rem; font-weight: 400; margin: 0 0 1rem; }
  .brand b { color: #0f62fe; }
  p.lede { color: #525252; font-size: 0.875rem; margin: 0 0 1.5rem; }
  label { display: block; font-size: 0.75rem; color: #525252; margin: 0 0 0.25rem; }
  input { width: 100%; height: 2.5rem; padding: 0 0.6rem; margin: 0 0 1rem; border: none;
    border-bottom: 1px solid #8d8d8d; background: #f4f4f4; font-size: 0.875rem; box-sizing: border-box; }
  input:focus { outline: 2px solid #0f62fe; outline-offset: -2px; }
  button { width: 100%; height: 2.5rem; background: #0f62fe; color: #ffffff; border: none;
    font-size: 0.875rem; cursor: pointer; }
  button:hover { background: #0353e9; }
  .err { border-left: 3px solid #da1e28; background: #fff1f1; padding: 0.6rem 0.8rem; font-size: 0.8rem; margin: 0 0 1rem; }
  .notice { border-left: 3px solid #24a148; background: #defbe6; padding: 0.6rem 0.8rem; font-size: 0.8rem; margin: 0 0 1rem; }
  .foot { color: #8d8d8d; font-size: 0.7rem; margin-top: 1.5rem; }
</style>{{end}}
