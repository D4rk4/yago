{{define "setup"}}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="referrer" content="no-referrer">
<title>Set up — yago admin</title>
{{template "authstyle"}}
</head>
<body>
<div class="card">
  <h1 class="brand">Set up <b>yago</b></h1>
  <p class="lede">Create the administrator account for this node.</p>
  {{if .Error}}<div class="err" role="alert">{{.Error}}</div>{{end}}
  <form method="post" action="/admin/setup">
    <label for="u">Username</label>
    <input id="u" name="username" autocomplete="username" autofocus required>
    <label for="p">Password</label>
    <input id="p" name="password" type="password" autocomplete="new-password" required>
    {{if .Wizard}}
    <fieldset class="modes">
      <legend>Node mode</legend>
      <label><input type="radio" name="mode" value="local" checked> Local-only — private index, no public exposure</label>
      <label><input type="radio" name="mode" value="peer"> Public peer — join the swarm, keep the search portal off</label>
      <label><input type="radio" name="mode" value="search"> Public search node — join the swarm and serve the public portal</label>
    </fieldset>
    <label for="pn">Peer name (optional)</label>
    <input id="pn" name="peer_name" value="{{.Defaults.PeerName}}" autocomplete="off">
    <label for="ah">Advertised host (autodetected)</label>
    <input id="ah" name="advertise_host" value="{{.Defaults.AdvertiseHost}}" autocomplete="off">
    <label for="sl">Seedlist URLs (comma-separated)</label>
    <input id="sl" name="seedlists" value="{{.Defaults.Seedlists}}" autocomplete="off">
    <label for="wf">Web search fallback (DDGS)</label>
    <select id="wf" name="web_fallback">
      <option value="disabled"{{if eq .Defaults.WebFallback "disabled"}} selected{{end}}>Disabled</option>
      <option value="explicit"{{if eq .Defaults.WebFallback "explicit"}} selected{{end}}>Only when requested</option>
      <option value="enabled"{{if eq .Defaults.WebFallback "enabled"}} selected{{end}}>Enabled on search miss</option>
      <option value="always"{{if eq .Defaults.WebFallback "always"}} selected{{end}}>Always</option>
    </select>
    {{end}}
    <button type="submit">Create administrator</button>
  </form>
  <div class="foot">yago — free software under the GNU AGPL v3.</div>
</div>
</body>
</html>{{end}}
